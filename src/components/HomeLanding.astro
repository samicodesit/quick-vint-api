<script>
  const heroVideo = document.querySelector(
    "[data-hero-video]",
  ) as HTMLVideoElement | null;

  async function openHeroFullscreen() {
    if (!heroVideo) return;
    try {
      if (heroVideo.requestFullscreen) {
        await heroVideo.requestFullscreen();
      } else if ((heroVideo as any).webkitEnterFullscreen) {
        (heroVideo as any).webkitEnterFullscreen();
      }
    } catch (err) {
      // ignore
    }
    try {
      await heroVideo.play();
    } catch (e) {}
  }

  document.querySelectorAll("[data-open-fullscreen]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      openHeroFullscreen();
    });
  });
</script>

