---
import type { SiteCopy, SiteLocale, SiteExtraHomeCopy } from "../i18n/site.js";

interface Props {
  copy: SiteCopy["home"];
  extra: SiteExtraHomeCopy;
  heroTitleAccent?: {
    before: string;
    accent: string;
    after: string;
  };
  heroSubtitleEmphasis?: string;
}

const { copy, extra, heroTitleAccent, heroSubtitleEmphasis } = Astro.props;

const chromeHref =
  "https://chromewebstore.google.com/detail/autolister-ai/mommklhpammnlojjobejddmidmdcalcl";

const subtitleParts =
  heroSubtitleEmphasis && copy.heroSubtitle.includes(heroSubtitleEmphasis)
    ? copy.heroSubtitle.split(heroSubtitleEmphasis)
    : null;
---

<!-- Hero Section -->
<div class="relative pt-32 pb-12 lg:pt-28 lg:pb-12 overflow-hidden bg-white">
  <div
    class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0"
  >
    <div
      class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-brand-100 rounded-full mix-blend-multiply filter blur-[80px] opacity-80"
    >
    </div>
    <div
      class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-purple-50 rounded-full mix-blend-multiply filter blur-[80px] opacity-80 animation-delay-2000"
    >
    </div>
    <div
      class="absolute -bottom-32 left-1/3 w-[600px] h-[600px] bg-indigo-50 rounded-full mix-blend-multiply filter blur-[80px] opacity-80 animation-delay-4000"
    >
    </div>
  </div>

  <div
    class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full lg:pt-12 lg:pb-8"
  >
    <div class="lg:grid lg:grid-cols-12 lg:gap-8 xl:gap-16 items-center">
      <div
        class="lg:col-span-5 text-center lg:text-left flex flex-col items-center lg:items-start opacity-0 animate-[fadeInUp_0.8s_ease-out_forwards]"
      >
        <div class="flex flex-wrap items-center gap-2 mb-8">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 border border-brand-100 text-brand-600 text-xs font-bold uppercase tracking-wider shadow-sm transition-colors cursor-default"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-brand-600"
              ></span>
            </span>
            #1 Vinted Description Generator
          </div>
          <div
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 border border-green-200 text-green-700 text-xs font-bold uppercase tracking-wider shadow-sm cursor-default"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
            {copy.heroBadgeSafe}
          </div>
        </div>

        <h1
          class="text-4xl sm:text-5xl lg:text-5xl xl:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6 text-slate-900 mt-4 lg:mt-0 text-balance"
        >
          {
            heroTitleAccent ? (
              <>
                {heroTitleAccent.before}{" "}
                <span class="gradient-text">{heroTitleAccent.accent}</span>{" "}
                {heroTitleAccent.after}
              </>
            ) : (
              copy.heroTitle
            )
          }
        </h1>

        <p
          class="text-lg sm:text-xl text-slate-600 mb-8 max-w-lg leading-relaxed font-medium"
        >
          {
            subtitleParts ? (
              <>
                {subtitleParts[0]}
                <strong class="text-slate-800 font-semibold">
                  {heroSubtitleEmphasis}
                </strong>
                {subtitleParts.slice(1).join(heroSubtitleEmphasis || "")}
              </>
            ) : (
              copy.heroSubtitle
            )
          }
        </p>

        <ul
          class="space-y-3 mb-10 text-left w-full max-w-md px-2 sm:px-0 list-none"
        >
          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-50 flex items-center justify-center mt-0.5 border border-brand-100 shadow-sm"
            >
              <svg
                class="w-4 h-4 text-brand-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="text-slate-700 font-semibold text-lg leading-snug"
              >{extra.heroBullet1}</span
            >
          </li>
          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-50 flex items-center justify-center mt-0.5 border border-brand-100 shadow-sm"
            >
              <svg
                class="w-4 h-4 text-brand-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="text-slate-700 font-semibold text-lg leading-snug"
              >{extra.heroBullet2}</span
            >
          </li>
          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-50 flex items-center justify-center mt-0.5 border border-brand-100 shadow-sm"
            >
              <svg
                class="w-4 h-4 text-brand-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="text-slate-700 font-semibold text-lg leading-snug"
              >{extra.heroBullet3}</span
            >
          </li>
          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-green-50 flex items-center justify-center mt-0.5 border border-green-100 shadow-sm"
            >
              <svg
                class="w-4 h-4 text-green-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
            </div>
            <span class="text-slate-700 font-semibold text-lg leading-snug"
              >{copy.heroBulletSafety}</span
            >
          </li>
        </ul>

        <div
          class="flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-4 w-full max-w-2xl px-2 sm:px-0"
        >
          <a
            href={chromeHref}
            target="_blank"
            rel="noreferrer"
            class="group relative inline-flex min-h-[76px] w-full sm:flex-1 items-center justify-start gap-3 px-6 py-4 text-left text-base font-bold text-white bg-brand-600 rounded-2xl hover:bg-brand-700 transition-all duration-200 hover:-translate-y-1 shadow-lg shadow-brand-600/30 overflow-hidden focus:ring-2 ring-brand-500 no-underline sm:px-7"
          >
            <div
              class="bg-white rounded-full p-0.5 shadow-sm shrink-0 self-center"
            >
              <svg
                viewBox="0 0 48 48"
                class="w-5 h-5 shrink-0 transition-transform group-hover:rotate-12 duration-500"
              >
                <defs>
                  <linearGradient
                    id="chrome-a"
                    x1="3.2"
                    y1="15"
                    x2="44.7"
                    y2="15"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop offset="0" stop-color="#d93025"></stop>
                    <stop offset="1" stop-color="#ea4335"></stop>
                  </linearGradient>
                  <linearGradient
                    id="chrome-b"
                    x1="20.7"
                    y1="47.6"
                    x2="41.5"
                    y2="11.6"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop offset="0" stop-color="#fcc934"></stop>
                    <stop offset="1" stop-color="#fbbc04"></stop>
                  </linearGradient>
                  <linearGradient
                    id="chrome-c"
                    x1="26.5"
                    y1="46.5"
                    x2="5.8"
                    y2="10.5"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop offset="0" stop-color="#1e8e3e"></stop>
                    <stop offset="1" stop-color="#34a853"></stop>
                  </linearGradient>
                </defs>
                <circle cx="24" cy="24" r="12" fill="#fff"></circle>
                <path
                  d="M24 12H44.78a24 24 0 0 0-41.56 0L13.6 30S24 12 24 12Z"
                  fill="url(#chrome-a)"></path>
                <circle cx="24" cy="24" r="9.5" fill="#1a73e8"></circle>
                <path
                  d="M34.39 30 24 48a24 24 0 0 0 20.78-36H24S34.39 30 34.39 30Z"
                  fill="url(#chrome-b)"></path>
                <path
                  d="M13.6 30 3.2 12A24 24 0 0 0 24 48l10.4-18S13.6 30 13.6 30Z"
                  fill="url(#chrome-c)"></path>
              </svg>
            </div>

            <span class="min-w-0 flex flex-col items-start leading-tight">
              <span class="break-words text-base font-bold"
                >{extra.addToChrome}</span
              >
              <span class="font-medium text-brand-100 opacity-90 mt-1 text-sm"
                >{extra.addToChromeNote}</span
              >
            </span>
          </a>

          <button
            data-open-fullscreen
            class="inline-flex min-h-[76px] w-full sm:w-auto sm:min-w-[220px] items-center justify-start gap-2 px-6 py-4 text-left text-base font-bold text-slate-800 bg-white border-2 border-slate-300 rounded-2xl hover:bg-slate-50 hover:border-slate-400 transition-all duration-200 hover:-translate-y-1 shadow-sm cursor-pointer sm:px-7"
          >
            <svg
              class="w-5 h-5 text-slate-900 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
            <span class="break-words leading-tight">{extra.watchDemo}</span>
          </button>
        </div>

        <div
          class="mt-8 flex items-start gap-4 p-4 rounded-xl bg-slate-50/50 border border-slate-100/60 max-w-md backdrop-blur-sm"
        >
          <img
            class="w-10 h-10 rounded-full border-2 border-white shadow-md shrink-0"
            src="/user-1.jpg"
            alt="User"
          />
          <div class="text-sm">
            <p class="text-slate-700 italic leading-relaxed">
              "I no longer have an excuse not to sell those clothes lying around
              😀. Thanks for this!"
            </p>
            <p
              class="text-slate-900 font-bold mt-2 text-xs uppercase tracking-wide"
            >
              — Otília N.
            </p>
          </div>
        </div>
      </div>

      <div
        class="lg:col-span-7 mt-12 lg:mt-0 relative opacity-0 animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]"
      >
        <div
          class="absolute -top-12 -right-12 w-72 h-72 bg-brand-100 rounded-full mix-blend-multiply filter blur-[60px] opacity-60"
        >
        </div>
        <div
          class="absolute -bottom-8 -left-8 w-64 h-64 bg-purple-100 rounded-full mix-blend-multiply filter blur-[60px] opacity-60"
        >
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden video-wrapper bg-white group cursor-pointer"
          data-open-fullscreen
        >
          <div class="aspect-video relative">
            <video
              data-hero-video
              class="w-full h-full object-cover"
              poster="/video-poster.png"
              src="/vid-promo.mp4"
              autoplay
              muted
              loop
              playsinline
              controls
            >
            </video>

            <div class="absolute top-4 right-4 z-20">
              <button
                data-open-fullscreen
                class="p-2.5 bg-black/40 backdrop-blur-md text-white rounded-full hover:bg-black/60 transition-all duration-200 hover:scale-110"
                aria-label="View Full Screen"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div class="mt-4 text-center">
          <p class="text-sm text-slate-500 font-medium">
            {extra.videoCaption}
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="relative border-y border-slate-100 bg-slate-50 py-16 lg:py-24 overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] sm:w-[800px] h-[400px] bg-green-500/5 blur-[100px] sm:blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-100/50 border border-green-200 text-green-700 text-sm font-semibold mb-6">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <span>{extra.safetyNativeBadge}</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-6 leading-tight">
        {extra.safetyHeading}
      </h2>
      <p class="text-lg md:text-xl text-slate-600 leading-relaxed">
        {extra.safetyBody}
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid lg:grid-cols-3 gap-6">
      
      <!-- Card 1: Bad Bots (Red) -->
      <div class="rounded-[2rem] border border-red-100 bg-white p-7 sm:p-9 shadow-sm flex flex-col relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-br from-red-50/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-red-100 text-red-600 shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </span>
            <span class="text-sm font-bold uppercase tracking-widest text-red-700">
              {extra.comparisonBotSubtitle}
            </span>
          </div>
          <div class="space-y-5 mt-auto">
            <div class="pb-5 border-b border-red-100/50">
              <p class="font-bold text-slate-900 mb-1.5">{extra.comparisonBotBullet1Title}</p>
              <p class="text-sm text-slate-600 leading-relaxed">{extra.comparisonBotBullet1Body}</p>
            </div>
            <div>
              <p class="font-bold text-slate-900 mb-1.5">{extra.comparisonBotBullet2Title}</p>
              <p class="text-sm text-slate-600 leading-relaxed">{extra.comparisonBotBullet2Body}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: AutoLister AI (Green, Featured) -->
      <div class="rounded-[2rem] border border-green-200 bg-white p-7 sm:p-9 shadow-[0_8px_40px_-12px_rgba(34,197,94,0.15)] ring-1 ring-green-500/10 flex flex-col relative overflow-hidden lg:scale-[1.02] z-10 bg-gradient-to-b from-white to-green-50/30">
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-green-400 to-green-600"></div>
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-green-100 text-green-700 shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <span class="text-sm font-bold uppercase tracking-widest text-green-700">
              AutoLister AI
            </span>
          </div>
          <div class="space-y-5 mt-auto">
            <div class="pb-5 border-b border-green-200/50">
              <p class="font-bold text-slate-900 mb-1.5 flex items-start sm:items-center gap-2">
                 <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5 sm:mt-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                 <span>{extra.comparisonAlBullet1Title}</span>
              </p>
              <p class="text-sm text-slate-600 leading-relaxed">{extra.comparisonAlBullet1Body}</p>
            </div>
            <div>
              <p class="font-bold text-slate-900 mb-1.5 flex items-start sm:items-center gap-2">
                 <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5 sm:mt-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                 <span>{extra.comparisonAlBullet2Title}</span>
              </p>
              <p class="text-sm text-slate-600 leading-relaxed">{extra.comparisonAlBullet2Body}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 3: The Catch (Dark Theme Bento) -->
      <div class="rounded-[2rem] border border-slate-800 bg-slate-950 p-7 sm:p-9 shadow-xl flex flex-col relative overflow-hidden group">
        <!-- Abstract gradient shapes -->
        <div class="absolute -right-8 -top-8 w-40 h-40 bg-brand-500/20 blur-[50px] rounded-full pointer-events-none transition-opacity group-hover:opacity-100 opacity-70"></div>
        <div class="absolute -left-8 -bottom-8 w-40 h-40 bg-blue-500/20 blur-[50px] rounded-full pointer-events-none transition-opacity group-hover:opacity-100 opacity-70"></div>
        
        <div class="relative z-10 flex flex-col h-full justify-center text-left">
          <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 text-slate-300 border border-white/10 text-[0.65rem] sm:text-xs font-bold uppercase tracking-widest w-fit mb-5 sm:mb-6">
            {extra.safetyCoreBadge}
          </p>
          <h3 class="text-xl sm:text-2xl font-bold tracking-tight text-white mb-3 sm:mb-4 leading-snug">
            {extra.safetyCoreTitle}
            <span class="text-slate-400 block mt-1">{extra.safetyCoreSubtitle}</span>
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            {extra.safetyCoreBody}
          </p>
        </div>
      </div>

      <!-- Feature Card 1 -->
      <div class="rounded-[2rem] border border-slate-200/60 bg-white/60 backdrop-blur-sm p-7 sm:p-8 hover:bg-white hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <div class="h-12 w-12 rounded-2xl bg-white border border-slate-100 flex items-center justify-center mb-5 sm:mb-6 shadow-sm">
          <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
          </svg>
        </div>
        <h3 class="font-bold text-lg text-slate-900 mb-2.5">{extra.safetyFeature1Title}</h3>
        <p class="text-slate-600 leading-relaxed text-sm">{extra.safetyFeature1Body}</p>
      </div>

      <!-- Feature Card 2 -->
      <div class="rounded-[2rem] border border-slate-200/60 bg-white/60 backdrop-blur-sm p-7 sm:p-8 hover:bg-white hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
         <div class="h-12 w-12 rounded-2xl bg-white border border-slate-100 flex items-center justify-center mb-5 sm:mb-6 shadow-sm">
          <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-lg text-slate-900 mb-2.5">{extra.safetyFeature2Title}</h3>
        <p class="text-slate-600 leading-relaxed text-sm">{extra.safetyFeature2Body}</p>
      </div>

      <!-- Feature Card 3 -->
      <div class="rounded-[2rem] border border-slate-200/60 bg-white/60 backdrop-blur-sm p-7 sm:p-8 hover:bg-white hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
         <div class="h-12 w-12 rounded-2xl bg-white border border-slate-100 flex items-center justify-center mb-5 sm:mb-6 shadow-sm">
          <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-lg text-slate-900 mb-2.5">{extra.safetyFeature3Title}</h3>
        <p class="text-slate-600 leading-relaxed text-sm">{extra.safetyFeature3Body}</p>
      </div>

