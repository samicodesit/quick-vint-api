---
import {
  DEFAULT_SITE_LOCALE,
  SITE_COPY,
  SUPPORTED_SITE_LOCALES,
  normalizeSiteLocale,
} from "../i18n/site.js";
import type { SiteLocale } from "../i18n/site.js";
import { localizedPath, LOCALE_FLAGS } from "../i18n/routing.js";

export interface Props {
  currentLocale?: string;
  basePath?: string;
  className?: string;
}

const {
  currentLocale = DEFAULT_SITE_LOCALE,
  basePath = "/",
  className = "",
} = Astro.props;

const locale = normalizeSiteLocale(currentLocale);
---

<div class={`relative ${className}`} data-lang-switcher>
  <!-- Trigger button -->
  <button
    type="button"
    data-lang-trigger
    aria-expanded="false"
    aria-haspopup="menu"
    class="w-full md:w-auto inline-flex items-center justify-between md:justify-start gap-2 px-3 py-2 rounded-xl text-sm font-semibold text-slate-700 hover:bg-slate-100 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-400"
  >
    <div class="flex items-center gap-2">
      <img
        src={`https://flagcdn.com/w20/${LOCALE_FLAGS[locale]}.png`}
        srcset={`https://flagcdn.com/w40/${LOCALE_FLAGS[locale]}.png 2x`}
        width="20"
        height="15"
        alt=""
        referrerpolicy="no-referrer"
        loading="lazy"
        class="rounded-[2px] shadow-sm"
      />
      <span>{SITE_COPY[locale].languageName}</span>
    </div>
    <svg
      data-chevron
      class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </button>

  <!-- Dropdown panel -->
  <ul
    role="menu"
    data-lang-panel
    aria-label={SITE_COPY[locale].nav.switcherLabel}
    class="absolute right-0 left-0 md:left-auto top-full mt-2 w-full md:w-48 bg-white rounded-2xl shadow-xl ring-1 ring-slate-200/80 py-1.5 z-[200] hidden"
  >
    {
      SUPPORTED_SITE_LOCALES.map((langCode: SiteLocale) => {
        const isSelected = langCode === locale;
        const href = localizedPath(langCode, basePath);
        return (
          <li role="none">
            <a
              href={href}
              role="menuitem"
              data-lang-option
              class={`flex items-center gap-3 px-4 py-2.5 text-sm font-medium transition-colors no-underline ${
                isSelected
                  ? "text-brand-700 bg-brand-50"
                  : "text-slate-700 hover:bg-slate-50"
              }`}
            >
              <img
                src={`https://flagcdn.com/w20/${LOCALE_FLAGS[langCode]}.png`}
                srcset={`https://flagcdn.com/w40/${LOCALE_FLAGS[langCode]}.png 2x`}
                width="20"
                height="15"
                alt=""
                referrerpolicy="no-referrer"
                loading="lazy"
                class="shrink-0 rounded-[2px] shadow-sm"
              />
              <span class="flex-1">{SITE_COPY[langCode].languageName}</span>
              {isSelected && (
                <svg
                  class="w-4 h-4 text-brand-600 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              )}
            </a>
          </li>
        );
      })
    }
  </ul>
</div>

<script>
  // Document-level listeners registered once per page regardless of switcher count
  let docListenersReady = false;

  function setupDocListeners() {
    if (docListenersReady) return;
    docListenersReady = true;

    document.addEventListener("click", (e) => {
      document
        .querySelectorAll<Element>("[data-lang-switcher][data-initialized]")
        .forEach((sw) => {
          if (sw.contains(e.target as Node)) return;
          const panel = sw.querySelector("[data-lang-panel]");
          const trigger = sw.querySelector<HTMLButtonElement>("[data-lang-trigger]");
          const chevron = sw.querySelector<HTMLElement>("[data-chevron]");
          if (panel && !panel.classList.contains("hidden")) {
            panel.classList.add("hidden");
            trigger?.setAttribute("aria-expanded", "false");
            if (chevron) chevron.style.transform = "";
          }
        });
    });

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      document
        .querySelectorAll<Element>("[data-lang-switcher][data-initialized]")
        .forEach((sw) => {
          const panel = sw.querySelector("[data-lang-panel]");
          const trigger = sw.querySelector<HTMLButtonElement>("[data-lang-trigger]");
          const chevron = sw.querySelector<HTMLElement>("[data-chevron]");
          if (panel && !panel.classList.contains("hidden")) {
            panel.classList.add("hidden");
            trigger?.setAttribute("aria-expanded", "false");
            if (chevron) chevron.style.transform = "";
            trigger?.focus();
          }
        });
    });
  }

  function initSwitcher(container: Element) {
    const trigger = container.querySelector(
      "[data-lang-trigger]",
    ) as HTMLButtonElement | null;
    const panel = container.querySelector("[data-lang-panel]");
    const chevron = container.querySelector("[data-chevron]") as HTMLElement;

    if (!trigger || !panel) return;

    // Preserve UTMs and queries
    if (window.location.search) {
      container
        .querySelectorAll<HTMLAnchorElement>("[data-lang-option]")
        .forEach((link) => {
          const base = link.getAttribute("href") || "/";
          link.href = base.includes("?") ? base : base + window.location.search;
        });
    }

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      if (panel!.classList.contains("hidden")) {
        panel!.classList.remove("hidden");
        trigger!.setAttribute("aria-expanded", "true");
        if (chevron) chevron.style.transform = "rotate(180deg)";
      } else {
        panel!.classList.add("hidden");
        trigger!.setAttribute("aria-expanded", "false");
        if (chevron) chevron.style.transform = "";
      }
    });
  }

  function initAll() {
    setupDocListeners();
    document.querySelectorAll("[data-lang-switcher]").forEach((sw) => {
      if (!sw.hasAttribute("data-initialized")) {
        sw.setAttribute("data-initialized", "true");
        initSwitcher(sw);
      }
    });
  }

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>
