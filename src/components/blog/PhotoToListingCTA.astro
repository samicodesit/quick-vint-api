---
import { CHROME_WEB_STORE_URL } from "../../utils/blog.js";

interface Props {
  locale?: "en" | "fr" | "de" | "nl";
}

const { locale = "en" } = Astro.props;

const copy = {
  en: {
    eyebrow: "Photo-to-listing writing",
    title: "Turn item photos into Vinted-ready text",
    body: "AutoLister AI generates titles, descriptions, and SEO-style hashtags from your item photos. Use it for one listing or batch drafts, then review before publishing.",
    cta: "Add to Chrome",
  },
  fr: {
    eyebrow: "Rédaction depuis vos photos",
    title: "Transformez vos photos en texte prêt pour Vinted",
    body: "AutoLister AI génère titres, descriptions et hashtags depuis vos photos. Utilisez-le pour une annonce ou des brouillons en lot, puis vérifiez avant de publier.",
    cta: "Ajouter à Chrome",
  },
  de: {
    eyebrow: "Texte aus Artikelfotos",
    title: "Verwandle Artikelfotos in Vinted-fertigen Text",
    body: "AutoLister AI erstellt Titel, Beschreibungen und SEO-ähnliche Hashtags aus deinen Fotos. Nutze es einzeln oder für Batch-Entwürfe, dann prüfe vor dem Veröffentlichen.",
    cta: "Zu Chrome hinzufügen",
  },
  nl: {
    eyebrow: "Tekst vanuit foto's",
    title: "Zet itemfoto's om naar Vinted-klare tekst",
    body: "AutoLister AI maakt titels, beschrijvingen en SEO-achtige hashtags vanuit je foto's. Gebruik het per advertentie of voor batch-concepten, en controleer voor publicatie.",
    cta: "Toevoegen aan Chrome",
  },
}[locale];
---

<aside class="my-10 rounded-2xl border border-slate-200 bg-slate-50 p-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="min-w-0">
      <p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-400">{copy.eyebrow}</p>
      <h3 class="text-base font-bold text-slate-900">{copy.title}</h3>
      <p class="mt-1 text-sm font-medium leading-6 text-slate-600">{copy.body}</p>
    </div>
    <a
      href={CHROME_WEB_STORE_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-track-event="chrome_store_click"
      data-track-context="blog_photo_to_listing"
      class="inline-flex shrink-0 items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-bold text-white no-underline transition hover:bg-slate-800"
    >
      {copy.cta}
    </a>
  </div>
</aside>
