---
interface Props {
  title?: string;
  body?: string;
}

const {
  title = "AutoLister AI handles the repetitive writing for you",
  body = "Use it when you already know what you want to sell, but don't want to rewrite titles, measurements, materials, condition notes, and buyer-friendly descriptions every time.",
} = Astro.props;
---

<aside class="my-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
    <div class="min-w-0 flex-1">
      <p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-400">Tool tip</p>
      <h3 class="text-base font-bold text-slate-900">{title}</h3>
      <p class="mt-1 text-sm font-medium leading-6 text-slate-600">{body}</p>
    </div>
  </div>
</aside>
