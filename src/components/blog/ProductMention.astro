---
interface Props {
  locale?: "en" | "fr" | "de" | "nl";
  title?: string;
  body?: string;
}

const { locale = "en" } = Astro.props;

const copy = {
  en: {
    eyebrow: "Tool tip",
    title: "AutoLister AI can draft listing text from photos",
    body: "Use it when you want buyer-friendly Vinted text from item photos. It works for one listing or batch drafts, then you review before publishing.",
  },
  fr: {
    eyebrow: "Astuce outil",
    title: "AutoLister AI peut rédiger le texte depuis vos photos",
    body: "Utilisez-le pour obtenir un texte Vinted depuis vos photos, pour une annonce ou des brouillons en lot. Vérifiez toujours avant publication.",
  },
  de: {
    eyebrow: "Tool-Tipp",
    title: "AutoLister AI kann Listing-Text aus Fotos entwerfen",
    body: "Nutze es für käuferfreundlichen Vinted-Text aus Fotos, einzeln oder als Batch-Entwürfe. Prüfe die Details vor dem Veröffentlichen.",
  },
  nl: {
    eyebrow: "Tooltip",
    title: "AutoLister AI kan advertentietekst uit foto's maken",
    body: "Gebruik het voor kopergerichte Vinted-tekst vanuit foto's, per advertentie of als batch-concepten. Controleer de details voor publicatie.",
  },
}[locale];

const {
  title = copy.title,
  body = copy.body,
} = Astro.props;
---

<aside class="my-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
    <div class="min-w-0 flex-1">
      <p class="mb-1 text-xs font-bold uppercase tracking-wide text-slate-400">{copy.eyebrow}</p>
      <h3 class="text-base font-bold text-slate-900">{title}</h3>
      <p class="mt-1 text-sm font-medium leading-6 text-slate-600">{body}</p>
    </div>
  </div>
</aside>
