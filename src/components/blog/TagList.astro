---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="flex flex-wrap gap-2 list-none p-0 m-0" aria-label="Tags">
      {tags.map((tag) => (
        <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
          #{tag}
        </li>
      ))}
    </ul>
  )
}
