---
import { getCollection } from "astro:content";
import BlogCard from "../../../../components/blog/BlogCard.astro";
import {
  BLOG_CATEGORIES,
  BLOG_COPY,
  LOCALIZED_BLOG_LOCALES,
  normalizeBlogLocale,
  type BlogCategory,
  type BlogLocale,
} from "../../../../i18n/blog.js";
import SiteLayout from "../../../../layouts/SiteLayout.astro";
import { getPublishedPosts, getCategoryUrl, type BlogPost } from "../../../../utils/blog.js";

export function getStaticPaths() {
  return LOCALIZED_BLOG_LOCALES.flatMap((lang) =>
    BLOG_CATEGORIES.map((category) => ({ params: { lang, category } })),
  );
}

const locale = normalizeBlogLocale(Astro.params.lang) as BlogLocale;
const category = Astro.params.category as BlogCategory;
const copy = BLOG_COPY[locale];
const posts = getPublishedPosts(
  ((await getCollection("blog")) as BlogPost[]).filter(
    (post) =>
      post.data.locale === locale &&
      post.data.category === category &&
      !post.data.draft,
  ),
);
const categoryLabel = copy.categories[category];
const canonicalUrl = `https://autolister.app${getCategoryUrl(locale, category)}`;
---

<SiteLayout
  title={`${categoryLabel} - AutoLister AI`}
  description={`${categoryLabel} guides for Vinted sellers and resellers from AutoLister AI.`}
  canonical={canonicalUrl}
  ogUrl={canonicalUrl}
  htmlLang={locale}
  currentLocale={locale}
  localeBasePath={`/blog/category/${category}`}
  switcherLocales={["en", "fr", "de", "nl"]}
>
  <main class="bg-white pt-28">
    <section class="bg-gradient-to-br from-brand-50 via-white to-indigo-50 py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <a href={`/${locale}/blog`} class="mb-8 inline-flex text-sm font-black text-brand-700 no-underline">
          ← {copy.backToBlog}
        </a>
        <p class="text-sm font-black uppercase tracking-[0.25em] text-brand-600">
          {copy.eyebrow}
        </p>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">
          {categoryLabel}
        </h1>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} />)}
      </div>
    </section>
  </main>
</SiteLayout>
