---
import HomeLanding from "../../components/HomeLanding.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  SITE_EXTRA_COPY,
  SITE_COPY,
  SUPPORTED_SITE_LOCALES,
  normalizeSiteLocale,
} from "../../i18n/site.js";
import type { SiteLocale } from "../../i18n/site.js";

export function getStaticPaths() {
  return SUPPORTED_SITE_LOCALES.filter((lang) => lang !== "en").map(
    (lang: SiteLocale) => ({ params: { lang } }),
  );
}

const locale = normalizeSiteLocale(Astro.params.lang);
const copy = SITE_COPY[locale];
const extra = SITE_EXTRA_COPY[locale];
const baseUrl = "https://autolister.app";
const canonicalPath = locale === "en" ? "/" : `/${locale}/`;
const canonical = `${baseUrl}${canonicalPath}`;
---

<SiteLayout
  canonical={canonical}
  title={copy.home.seoTitle}
  description={copy.home.seoDescription}
  ogUrl={canonical}
  ogImage="https://autolister.app/banner.png"
  htmlLang={locale}
  currentLocale={locale}
  localeBasePath="/"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/de/`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/es/`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/it/`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/`} />
  </Fragment>

  <HomeLanding copy={copy.home} extra={extra.home} locale={locale} />
</SiteLayout>
