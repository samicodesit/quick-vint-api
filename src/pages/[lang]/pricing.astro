---
import PricingPage from "../../components/PricingPage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  SITE_EXTRA_COPY,
  SITE_COPY,
  SUPPORTED_SITE_LOCALES,
  normalizeSiteLocale,
} from "../../i18n/site.js";
import { getPricingDisplay } from "../../utils/pricingDisplay.js";
import type { SiteLocale } from "../../i18n/site.js";

export function getStaticPaths() {
  return SUPPORTED_SITE_LOCALES.filter((lang) => lang !== "en").map(
    (lang: SiteLocale) => ({ params: { lang } }),
  );
}

const locale = normalizeSiteLocale(Astro.params.lang);
const copy = SITE_COPY[locale];
const extra = SITE_EXTRA_COPY[locale];
const baseUrl = "https://autolister.app";
const canonicalPath = locale === "en" ? "/pricing" : `/${locale}/pricing`;
const canonical = `${baseUrl}${canonicalPath}`;
const {
  isCurrent: isCurrentPricing,
  limits,
  creditPack,
} = getPricingDisplay(import.meta.env.PUBLIC_PRICING_DISPLAY_MODE, {
  listingsPerDay: extra.pricing.listingsPerDay,
  listingsPerMonth: extra.pricing.listingsPerMonth,
  noDailyLimit: extra.pricing.noDailyLimit,
});
---

<SiteLayout
  title={copy.pricing.seoTitle}
  description={copy.pricing.seoDescription}
  canonical={canonical}
  ogUrl={canonical}
  htmlLang={locale}
  currentLocale={locale}
  localeBasePath="/pricing"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/pricing`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/pricing`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/de/pricing`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/pricing`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/pricing`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/es/pricing`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/it/pricing`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/pricing`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/pricing`} />
  </Fragment>

  <PricingPage
    copy={copy.pricing}
    extra={extra.pricing}
    limits={limits}
    creditPack={creditPack}
    isCurrentPricing={isCurrentPricing}
  />

  <script>
    import "../../scripts/pricing.js";
  </script>
</SiteLayout>
