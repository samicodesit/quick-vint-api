---
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  SITE_EXTRA_COPY,
  SITE_COPY,
  SUPPORTED_SITE_LOCALES,
  normalizeSiteLocale,
} from "../../i18n/site.js";
import type { SiteLocale } from "../../i18n/site.js";

export function getStaticPaths() {
  return SUPPORTED_SITE_LOCALES.filter((lang) => lang !== "en").map(
    (lang: SiteLocale) => ({ params: { lang } }),
  );
}

const locale = normalizeSiteLocale(Astro.params.lang);
const copy = SITE_COPY[locale];
const extra = SITE_EXTRA_COPY[locale];
const baseUrl = "https://autolister.app";
const canonicalPath = locale === "en" ? "/pricing" : `/${locale}/pricing`;
const canonical = `${baseUrl}${canonicalPath}`;
---

<SiteLayout
  title={copy.pricing.seoTitle}
  description={copy.pricing.seoDescription}
  canonical={canonical}
  ogUrl={canonical}
  htmlLang={locale}
  currentLocale={locale}
  localeBasePath="/pricing"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/pricing`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/pricing`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/de/pricing`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/pricing`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/pricing`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/es/pricing`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/it/pricing`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/pricing`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/pricing`} />
  </Fragment>

  <div class="bg-slate-50 pb-14 pt-32 lg:pt-40 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-brand-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute top-20 right-10 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>

    <!-- Hero tagline -->
    <div class="text-center max-w-3xl mx-auto mb-10 relative z-10">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 mb-4 tracking-tight">
        {copy.pricing.heading}
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-600 to-violet-600">{copy.pricing.headingAccent}</span>
      </h1>
      <p class="text-lg text-slate-500 font-medium">
        {extra.pricing.freeTagline}
      </p>
    </div>

    <!-- Safety Trust Banner -->
    <div class="max-w-[1200px] mx-auto relative z-10 mb-10">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 bg-green-50 border border-green-200 rounded-2xl px-6 py-4">
        <div class="flex items-center gap-2 text-green-700">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          <span class="font-bold text-sm">{extra.pricing.safetyBannerTitle}</span>
        </div>
        <div class="flex items-center gap-4 text-xs text-green-600 font-semibold">
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.safetyZeroMass}</span>
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.safetyZeroApi}</span>
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.safetyZeroBan}</span>
        </div>
      </div>
    </div>

    <!-- Subscription cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 max-w-[1200px] mx-auto relative z-10">

      <!-- Starter -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{extra.pricing.starterPlanName}</h3>
          <p class="text-sm text-slate-500">{extra.pricing.starterPlanSubtitle}</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;5.99</span>
            <span class="text-slate-500 text-sm">{extra.pricing.perMonth}</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">80 {extra.pricing.creditsPerMonth}</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.075 {extra.pricing.perCredit}</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.phoneUploadUnlimited}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.creditRolloverFeature} (240)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.listingCompleteness}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.standardSupport}</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer"
          data-plan="starter_v2"
          id="btn-starter"
        >
          <span class="btn-text">{extra.pricing.subscribeCta}</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Plus -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{extra.pricing.plusPlanName}</h3>
          <p class="text-sm text-slate-500">{extra.pricing.plusPlanSubtitle}</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;9.99</span>
            <span class="text-slate-500 text-sm">{extra.pricing.perMonth}</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">200 {extra.pricing.creditsPerMonth}</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.05 {extra.pricing.perCredit}</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.everythingInStarter}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.listingPreferences}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.smartReGen}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.creditRolloverFeature} (600)</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer"
          data-plan="plus"
          id="btn-plus"
        >
          <span class="btn-text">{extra.pricing.subscribeCta}</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Pro (Most Popular) -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 border-2 border-brand-400 flex flex-col overflow-visible">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-fit z-20">
          <span class="bg-gradient-to-r from-brand-600 to-violet-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg shadow-brand-600/80 uppercase tracking-wide ring-4 ring-white">
            {extra.pricing.mostPopular}
          </span>
        </div>
        <div class="mb-5 mt-2">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{extra.pricing.proPlanName}</h3>
          <p class="text-sm text-slate-500">{extra.pricing.proPlanSubtitle}</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-brand-600">&euro;14.99</span>
            <span class="text-slate-500 text-sm">{extra.pricing.perMonth}</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">400 {extra.pricing.creditsPerMonth}</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-brand-50 text-brand-700 border border-brand-200">&euro;0.037 {extra.pricing.perCredit}</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.everythingInPlus}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.creditRolloverFeature} (1,200)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.toneControl}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.emojiSupport}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.multiLangBatch}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.listingTips}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.prioritySupport24h}</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-brand-600 text-white hover:bg-brand-700 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer shadow-lg shadow-brand-300"
          data-plan="pro_v2"
          id="btn-pro"
        >
          <span class="btn-text">{extra.pricing.subscribeCta}</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Business -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{extra.pricing.businessPlanName}</h3>
          <p class="text-sm text-slate-500">{extra.pricing.forVintedProSellers}</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;24.99</span>
            <span class="text-slate-500 text-sm">{extra.pricing.perMonth}</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">1,000 {extra.pricing.creditsPerMonth}</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.025 {extra.pricing.perCredit}</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.everythingInPro}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.priorityProcessing}</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.creditRolloverFeature} (3,000)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{extra.pricing.dedicatedSupport}</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all duration-200 active:scale-95 shadow-lg shadow-slate-200 flex items-center justify-center cursor-pointer"
          data-plan="business_v2"
          id="btn-business"
        >
          <span class="btn-text">{extra.pricing.subscribeCta}</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

    </div>

    <!-- Closet Clear Pack bar -->
    <div class="max-w-[1200px] mx-auto relative z-10 mt-6">
      <div class="bg-white border border-slate-200 rounded-3xl px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-5">
        <div>
          <p class="font-bold text-slate-900 text-base mb-1">{extra.pricing.packBarTitle} &mdash; &euro;3.99 one-time</p>
          <p class="text-sm text-slate-500">{extra.pricing.packBarDesc}</p>
          <span class="inline-flex items-center mt-2 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200">&euro;0.27 {extra.pricing.perCredit}</span>
        </div>
        <button
          class="shrink-0 px-7 py-3 rounded-xl font-bold text-sm bg-emerald-600 text-white hover:bg-emerald-700 transition-all duration-200 active:scale-95 cursor-pointer"
          id="btn-pack"
        >
          <span class="btn-text">{extra.pricing.packBarCta}</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>
    </div>

  </div>

  <!-- Footer strip -->
  <div class="border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-center md:text-left">
        <span class="flex items-center gap-2 text-gray-700 font-medium">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          {extra.pricing.noCard}
        </span>
        <span class="block text-sm text-gray-500 mt-1 ml-7">{extra.pricing.instantAccess}</span>
      </div>
      <div class="text-center md:text-right">
        <p class="text-sm text-gray-500">{extra.pricing.helpChoosing}</p>
        <a href="mailto:support@autolister.app" class="text-gray-900 font-medium hover:underline decoration-blue-500 underline-offset-4">
          {extra.pricing.emailSupport}
        </a>
      </div>
    </div>
  </div>
  <script>
    import "../../scripts/pricing.js";
  </script>
</SiteLayout>

<style>
  button.state-download {
    background-color: #059669 !important;
    color: white !important;
    border-color: #059669 !important;
  }
  button.state-download:hover {
    background-color: #047857 !important;
    border-color: #047857 !important;
  }
  button.state-signin {
    background-color: #7c3aed !important;
    color: white !important;
    border-color: #7c3aed !important;
  }
  button.state-signin:hover {
    background-color: #6d28d9 !important;
    border-color: #6d28d9 !important;
  }
  button.state-current {
    background-color: #10b981 !important;
    color: white !important;
    border-color: #10b981 !important;
    cursor: default;
    pointer-events: none;
  }
  button.state-disabled {
    background-color: #9ca3af !important;
    color: white !important;
    border-color: #9ca3af !important;
    cursor: not-allowed;
    pointer-events: none;
  }
  button:disabled {
    opacity: 0.7 !important;
    cursor: not-allowed !important;
    pointer-events: none !important;
  }
</style>
