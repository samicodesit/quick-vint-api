---
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  SITE_EXTRA_COPY,
  SITE_COPY,
  SUPPORTED_SITE_LOCALES,
  normalizeSiteLocale,
} from "../../i18n/site.js";
import type { SiteLocale } from "../../i18n/site.js";

export function getStaticPaths() {
  return SUPPORTED_SITE_LOCALES.filter((lang) => lang !== "en").map(
    (lang: SiteLocale) => ({ params: { lang } }),
  );
}

const locale = normalizeSiteLocale(Astro.params.lang);
const copy = SITE_COPY[locale];
const extra = SITE_EXTRA_COPY[locale];
const baseUrl = "https://autolister.app";
const canonicalPath = locale === "en" ? "/pricing" : `/${locale}/pricing`;
const canonical = `${baseUrl}${canonicalPath}`;
---

<SiteLayout
  title={copy.pricing.seoTitle}
  description={copy.pricing.seoDescription}
  canonical={canonical}
  ogUrl={canonical}
  htmlLang={locale}
  currentLocale={locale}
  localeBasePath="/pricing"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/pricing`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/pricing`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/de/pricing`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/pricing`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/pricing`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/es/pricing`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/it/pricing`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/pricing`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/pricing`} />
  </Fragment>

  <div
    class="bg-slate-50 pb-14 pt-32 lg:pt-40 px-4 sm:px-6 lg:px-8 relative overflow-hidden"
  >
    <!-- Decorative background blobs -->
    <div
      class="absolute top-20 left-10 w-72 h-72 bg-brand-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"
    >
    </div>
    <div
      class="absolute top-20 right-10 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"
    >
    </div>

    <div
      class="text-center max-w-3xl mx-auto mb-16 relative z-10 transition-all duration-700 ease-out transform translate-y-0 opacity-100"
    >
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 mb-6 tracking-tight"
      >
        {copy.pricing.heading}
        <span
          class="bg-clip-text text-transparent bg-gradient-to-r from-brand-600 to-violet-600"
          >{copy.pricing.headingAccent}</span
        >
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
        {copy.pricing.subtitle}
        <span class="block mt-2">{copy.pricing.subtitleLine2}</span>
      </p>
    </div>

    <!-- Safety Trust Banner -->
    <div class="max-w-[1400px] mx-auto relative z-10 mb-8">
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 bg-green-50 border border-green-200 rounded-2xl px-6 py-4"
      >
        <div class="flex items-center gap-2 text-green-700">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
          <span class="font-bold text-sm"
            >{extra.pricing.safetyBannerTitle}</span
          >
        </div>
        <div
          class="flex items-center gap-4 text-xs text-green-600 font-semibold"
        >
          <span class="flex items-center gap-1">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M5 13l4 4L19 7"></path></svg
            >
            {extra.pricing.safetyZeroMass}
          </span>
          <span class="flex items-center gap-1">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M5 13l4 4L19 7"></path></svg
            >
            {extra.pricing.safetyZeroApi}
          </span>
          <span class="flex items-center gap-1">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
