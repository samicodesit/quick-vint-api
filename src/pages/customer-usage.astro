---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Custom Business Usage - AutoLister AI"
  description="View your AutoLister AI Custom Business usage and limits."
  canonical={null}
  ogUrl="https://autolister.app/customer-usage"
  htmlLang="en"
  minimalChrome={true}
>
  <main class="usage-page">
    <section class="usage-shell" aria-live="polite">
      <div class="ambient" aria-hidden="true"></div>

      <header class="topbar">
        <a class="brand" href="/" aria-label="AutoLister AI home">
          <span class="brand-mark">A</span>
          <span>AutoLister AI</span>
        </a>
        <span class="secure-pill">Private usage link</span>
      </header>

      <section class="hero-panel">
        <div>
          <p class="eyebrow">Custom Business setup</p>
          <h1 id="headline">Loading your usage...</h1>
          <p id="subline" class="subline">
            Checking the current allowance for this account.
          </p>
        </div>
        <div class="status-card">
          <span id="statusDot" class="status-dot"></span>
          <span id="statusText">Checking</span>
        </div>
      </section>

      <section id="errorPanel" class="message-panel hidden">
        <h2>Usage link unavailable</h2>
        <p id="errorMessage">
          This link could not be verified. Please contact support and we will
          check your setup.
        </p>
        <a href="mailto:support@autolister.app">Contact support</a>
      </section>

      <section id="usagePanel" class="usage-grid hidden">
        <article class="metric-card metric-card-primary">
          <div class="metric-top">
            <span>Available now</span>
            <strong id="availableNow">0</strong>
          </div>
          <p id="availableNote">
            Listings available based on your daily and monthly balance.
          </p>
        </article>

        <article class="metric-card">
          <div class="metric-top">
            <span>Daily usage</span>
            <strong id="dailyValue">0 / 100</strong>
          </div>
          <div class="meter">
            <span id="dailyBar"></span>
          </div>
          <p id="dailyRemaining">100 remaining today</p>
        </article>

        <article class="metric-card">
          <div class="metric-top">
            <span>Monthly usage</span>
            <strong id="monthlyValue">0 / 1000</strong>
          </div>
          <div class="meter">
            <span id="monthlyBar"></span>
          </div>
          <p id="monthlyRemaining">1000 remaining this cycle</p>
        </article>
      </section>

      <section id="detailsPanel" class="details-panel hidden">
        <div>
          <span class="detail-label">Plan</span>
          <strong id="planName">Custom Business setup</strong>
        </div>
        <div>
          <span class="detail-label">Billing cycle</span>
          <strong id="cycleDate">Active</strong>
        </div>
        <div>
          <span class="detail-label">Account</span>
          <strong id="accountEmail">-</strong>
        </div>
      </section>

      <p id="extensionNote" class="fine-note hidden">
        Your custom limits are active here. The extension may briefly show the
        standard Business limits until the next update reaches your browser.
      </p>
    </section>
  </main>

  <style>
    :root {
      --ink: #16201a;
      --muted: #66736c;
      --line: rgba(22, 32, 26, 0.12);
      --panel: rgba(255, 255, 255, 0.82);
      --green: #0e7a4f;
      --green-dark: #09573a;
      --mint: #c7f2dc;
      --gold: #c88a1f;
    }

    body {
      background:
        radial-gradient(circle at 18% 12%, rgba(199, 242, 220, 0.72), transparent 34rem),
        linear-gradient(135deg, #fbfcf8 0%, #eef8f1 48%, #fff8ea 100%);
    }

    .usage-page {
      min-height: 100vh;
      padding: 22px;
      color: var(--ink);
      font-family:
        Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
        "Segoe UI", sans-serif;
    }

    .usage-shell {
      position: relative;
      width: min(100%, 1060px);
      min-height: calc(100vh - 44px);
      margin: 0 auto;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.72);
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.58);
      box-shadow: 0 26px 80px rgba(29, 55, 39, 0.16);
      backdrop-filter: blur(24px);
    }

    .ambient {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(
        115deg,
        rgba(14, 122, 79, 0.2),
        rgba(255, 255, 255, 0),
        rgba(200, 138, 31, 0.2),
        rgba(199, 242, 220, 0.32)
      );
      background-size: 220% 220%;
      animation: ambientShift 12s ease-in-out infinite alternate;
    }

    .topbar,
    .hero-panel,
    .usage-grid,
    .details-panel,
    .message-panel,
    .fine-note {
      position: relative;
      z-index: 1;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 24px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--ink);
      font-weight: 800;
      text-decoration: none;
    }

    .brand-mark {
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 10px;
      color: white;
      background: linear-gradient(135deg, var(--green), var(--gold));
      box-shadow: 0 12px 24px rgba(14, 122, 79, 0.22);
    }

    .secure-pill {
      border: 1px solid rgba(14, 122, 79, 0.22);
      border-radius: 999px;
      padding: 8px 12px;
      color: var(--green-dark);
      background: rgba(255, 255, 255, 0.62);
      font-size: 13px;
      font-weight: 700;
    }

    .hero-panel {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 24px;
      align-items: end;
      padding: 48px 48px 30px;
    }

    .eyebrow {
      margin: 0 0 12px;
      color: var(--green-dark);
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      max-width: 720px;
      margin: 0;
      font-size: clamp(40px, 6vw, 76px);
      line-height: 0.96;
      letter-spacing: 0;
    }

    .subline {
      max-width: 620px;
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.6;
    }

    .status-card {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-width: 154px;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px 16px;
      background: rgba(255, 255, 255, 0.78);
      color: var(--ink);
      font-weight: 800;
      box-shadow: 0 16px 34px rgba(22, 32, 26, 0.08);
    }

    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--gold);
      box-shadow: 0 0 0 5px rgba(200, 138, 31, 0.14);
    }

    .status-dot.active {
      background: var(--green);
      box-shadow: 0 0 0 5px rgba(14, 122, 79, 0.14);
    }

    .usage-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
      padding: 0 48px 16px;
    }

    .metric-card,
    .message-panel {
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 22px;
      background: var(--panel);
      box-shadow: 0 16px 40px rgba(22, 32, 26, 0.08);
    }

    .metric-card-primary {
      color: white;
      background: linear-gradient(135deg, var(--green-dark), var(--green));
    }

    .metric-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }

    .metric-top span,
    .detail-label {
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .metric-card-primary .metric-top span,
    .metric-card-primary p {
      color: rgba(255, 255, 255, 0.76);
    }

    .metric-top strong {
      white-space: nowrap;
      font-size: 28px;
      line-height: 1;
    }

    .metric-card p {
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .meter {
      width: 100%;
      height: 9px;
      margin-top: 24px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(22, 32, 26, 0.1);
    }

    .meter span {
      display: block;
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--green), var(--gold));
      transition: width 500ms ease;
    }

    .details-panel {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      padding: 0 48px 22px;
    }

    .details-panel div {
      border-top: 1px solid var(--line);
      padding-top: 18px;
    }

    .details-panel strong {
      display: block;
      margin-top: 6px;
      font-size: 16px;
    }

    .fine-note {
      margin: 0 48px 40px;
      border: 1px solid rgba(200, 138, 31, 0.24);
      border-radius: 16px;
      padding: 14px 16px;
      color: #735216;
      background: rgba(255, 248, 234, 0.76);
      font-size: 14px;
      line-height: 1.5;
    }

    .message-panel {
      margin: 0 48px 48px;
      max-width: 680px;
    }

    .message-panel h2 {
      margin: 0 0 10px;
      font-size: 28px;
    }

    .message-panel p {
      color: var(--muted);
      line-height: 1.6;
    }

    .message-panel a {
      color: var(--green-dark);
      font-weight: 800;
    }

    .hidden {
      display: none;
    }

    @keyframes ambientShift {
      0% {
        background-position: 0% 50%;
      }

      100% {
        background-position: 100% 50%;
      }
    }

    @media (max-width: 760px) {
      .usage-page {
        padding: 10px;
      }

      .usage-shell {
        min-height: calc(100vh - 20px);
        border-radius: 22px;
      }

      .topbar {
        padding: 18px;
      }

      .secure-pill {
        display: none;
      }

      .hero-panel,
      .usage-grid,
      .details-panel {
        grid-template-columns: 1fr;
        padding-left: 20px;
        padding-right: 20px;
      }

      .hero-panel {
        padding-top: 34px;
      }

      h1 {
        font-size: 42px;
      }

      .status-card {
        width: 100%;
      }

      .fine-note,
      .message-panel {
        margin-left: 20px;
        margin-right: 20px;
      }
    }
  </style>

  <script>
    const params = new URLSearchParams(window.location.search);
    const token = params.get("token") || "";

    const els = {
      headline: document.getElementById("headline"),
      subline: document.getElementById("subline"),
      statusDot: document.getElementById("statusDot"),
      statusText: document.getElementById("statusText"),
      errorPanel: document.getElementById("errorPanel"),
      errorMessage: document.getElementById("errorMessage"),
      usagePanel: document.getElementById("usagePanel"),
      detailsPanel: document.getElementById("detailsPanel"),
      availableNow: document.getElementById("availableNow"),
      availableNote: document.getElementById("availableNote"),
      dailyValue: document.getElementById("dailyValue"),
      dailyBar: document.getElementById("dailyBar"),
      dailyRemaining: document.getElementById("dailyRemaining"),
      monthlyValue: document.getElementById("monthlyValue"),
      monthlyBar: document.getElementById("monthlyBar"),
      monthlyRemaining: document.getElementById("monthlyRemaining"),
      planName: document.getElementById("planName"),
      cycleDate: document.getElementById("cycleDate"),
      accountEmail: document.getElementById("accountEmail"),
      extensionNote: document.getElementById("extensionNote"),
    };

    function formatDate(value) {
      if (!value) return "Active";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return "Active";
      return date.toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
    }

    function formatLimit(used, limit) {
      if (limit === null || limit === undefined) return `${used}`;
      return `${used} / ${limit}`;
    }

    function remainingText(value, label) {
      if (value === null || value === undefined) return "No daily cap";
      return `${Math.max(0, value)} remaining ${label}`;
    }

    function setBar(el, percent) {
      if (!el) return;
      el.style.width = `${Math.max(0, Math.min(100, Number(percent || 0)))}%`;
    }

    function showError(message) {
      els.statusText.textContent = "Unavailable";
      els.headline.textContent = "Usage link unavailable";
      els.subline.textContent =
        "Please contact support and we will check your setup.";
      els.errorMessage.textContent = message;
      els.errorPanel.classList.remove("hidden");
      els.usagePanel.classList.add("hidden");
      els.detailsPanel.classList.add("hidden");
      els.extensionNote.classList.add("hidden");
    }

    async function loadUsage() {
      if (!token) {
        showError("This usage link is missing its access token.");
        return;
      }

      const response = await fetch(
        `/api/customer/usage?token=${encodeURIComponent(token)}`,
        {
          headers: { Accept: "application/json" },
        },
      );
      const payload = await response.json().catch(() => ({}));

      if (!response.ok) {
        showError(payload.error || "This usage link could not be verified.");
        return;
      }

      const daily = payload.usage.daily;
      const monthly = payload.usage.monthly;
      const setup = payload.setup;
      const active = setup.status === "active";

      els.headline.textContent = active
        ? "Your custom limits are active"
        : "Your setup is being prepared";
      els.subline.textContent = active
        ? "This page shows the correct allowance for your AutoLister AI account."
        : "Once payment is complete, this page will show your active limits.";
      els.statusText.textContent = active ? "Active" : "Pending";
      els.statusDot.classList.toggle("active", active);

      els.availableNow.textContent = String(payload.usage.availableNow || 0);
      els.availableNote.textContent =
        payload.usage.message ||
        "Listings available based on your daily and monthly balance.";

      els.dailyValue.textContent = formatLimit(daily.used, daily.limit);
      els.dailyRemaining.textContent = remainingText(daily.remaining, "today");
      setBar(els.dailyBar, daily.percent);

      els.monthlyValue.textContent = formatLimit(monthly.used, monthly.limit);
      els.monthlyRemaining.textContent = remainingText(
        monthly.remaining,
        "this cycle",
      );
      setBar(els.monthlyBar, monthly.percent);

      els.planName.textContent = setup.label || "Custom Business setup";
      els.cycleDate.textContent = formatDate(
        setup.customLimitExpiresAt || setup.currentPeriodEnd,
      );
      els.accountEmail.textContent = payload.customer.email || "-";

      els.usagePanel.classList.remove("hidden");
      els.detailsPanel.classList.remove("hidden");
      els.errorPanel.classList.add("hidden");
      els.extensionNote.classList.toggle(
        "hidden",
        !payload.note.extensionDisplayMayLag,
      );
    }

    loadUsage().catch(() => {
      showError("Usage is temporarily unavailable. Please try again later.");
    });
  </script>
</SiteLayout>
