---
import HomeLanding from "../components/HomeLanding.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { SITE_EXTRA_COPY, SITE_COPY } from "../i18n/site.js";

const baseUrl = "https://autolister.app";
const copy = SITE_COPY.en;
const extra = SITE_EXTRA_COPY.en;
---

<SiteLayout
  canonical={`${baseUrl}/`}
  title={copy.home.seoTitle}
  description={copy.home.seoDescription}
  ogUrl={`${baseUrl}/`}
  ogImage="https://autolister.app/banner.png"
  htmlLang="en"
  currentLocale="en"
  localeBasePath="/"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr/`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/de/`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/nl/`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/pl/`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/es/`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/it/`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/pt/`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/`} />
  </Fragment>

  <HomeLanding copy={copy.home} extra={extra.home} locale="en" />
</SiteLayout>
