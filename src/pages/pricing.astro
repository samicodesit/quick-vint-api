---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Pricing - AutoLister AI"
  description="Discover our simple and transparent pricing plans for AutoLister AI. Choose the perfect plan for your selling journey on Vinted, with options for every seller type. Scale up or down at any time."
  canonical="https://autolister.app/pricing"
  ogUrl="https://autolister.app/pricing"
  htmlLang="en"
  currentLocale="en"
  localeBasePath="/pricing"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="https://autolister.app/pricing" />
    <link rel="alternate" hreflang="fr" href="https://autolister.app/fr/pricing" />
    <link rel="alternate" hreflang="de" href="https://autolister.app/de/pricing" />
    <link rel="alternate" hreflang="nl" href="https://autolister.app/nl/pricing" />
    <link rel="alternate" hreflang="pl" href="https://autolister.app/pl/pricing" />
    <link rel="alternate" hreflang="es" href="https://autolister.app/es/pricing" />
    <link rel="alternate" hreflang="it" href="https://autolister.app/it/pricing" />
    <link rel="alternate" hreflang="pt" href="https://autolister.app/pt/pricing" />
    <link rel="alternate" hreflang="x-default" href="https://autolister.app/pricing" />
  </Fragment>

  <div class="bg-slate-50 pb-14 pt-32 lg:pt-40 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-brand-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute top-20 right-10 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>

    <!-- Hero tagline -->
    <div class="text-center max-w-3xl mx-auto mb-10 relative z-10">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 mb-4 tracking-tight">
        Simple, Transparent <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-600 to-violet-600">Pricing</span>
      </h1>
      <p class="text-lg text-slate-500 font-medium">
        Start free with 13 credits &mdash; no card required.
      </p>
    </div>

    <!-- Safety Trust Banner -->
    <div class="max-w-[1200px] mx-auto relative z-10 mb-10">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 bg-green-50 border border-green-200 rounded-2xl px-6 py-4">
        <div class="flex items-center gap-2 text-green-700">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          <span class="font-bold text-sm">The only Vinted tool your account is genuinely safe with.</span>
        </div>
        <div class="flex items-center gap-4 text-xs text-green-600 font-semibold">
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>0 mass actions</span>
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>0 API hooks</span>
          <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>0 ban risk</span>
        </div>
      </div>
    </div>

    <!-- Subscription cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 max-w-[1200px] mx-auto relative z-10">

      <!-- Starter -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">Starter</h3>
          <p class="text-sm text-slate-500">For casual sellers</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;5.99</span>
            <span class="text-slate-500 text-sm">/mo</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">80 credits/mo</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.075 per credit</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Unlimited Phone Upload</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Credit rollover (up to 240)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Listing completeness score</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Standard support</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer"
          data-plan="starter_v2"
          id="btn-starter"
        >
          <span class="btn-text">Subscribe</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Plus -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">Plus</h3>
          <p class="text-sm text-slate-500">For regular sellers</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;9.99</span>
            <span class="text-slate-500 text-sm">/mo</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">200 credits/mo</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.05 per credit</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Everything in Starter</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Listing Preferences</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Smart Re-Gen</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Credit rollover (up to 600)</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer"
          data-plan="plus"
          id="btn-plus"
        >
          <span class="btn-text">Subscribe</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Pro (Most Popular) -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 border-2 border-brand-400 flex flex-col overflow-visible">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-fit z-20">
          <span class="bg-gradient-to-r from-brand-600 to-violet-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg shadow-brand-600/80 uppercase tracking-wide ring-4 ring-white">
            Most Popular
          </span>
        </div>
        <div class="mb-5 mt-2">
          <h3 class="text-xl font-bold text-slate-900 mb-1">Pro</h3>
          <p class="text-sm text-slate-500">For active sellers</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-brand-600">&euro;14.99</span>
            <span class="text-slate-500 text-sm">/mo</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">400 credits/mo</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-brand-50 text-brand-700 border border-brand-200">&euro;0.037 per credit</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Everything in Plus</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Credit rollover (up to 1,200)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Tone Control</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Emoji Support</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Multi-language batch</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Listing improvement tips</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Priority support (24h)</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-brand-600 text-white hover:bg-brand-700 transition-all duration-200 active:scale-95 flex items-center justify-center cursor-pointer shadow-lg shadow-brand-300"
          data-plan="pro_v2"
          id="btn-pro"
        >
          <span class="btn-text">Subscribe</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

      <!-- Business -->
      <div class="group relative bg-white rounded-3xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-200 flex flex-col">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-slate-900 mb-1">Business</h3>
          <p class="text-sm text-slate-500">For power sellers</p>
        </div>
        <div class="mb-1">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-slate-900">&euro;24.99</span>
            <span class="text-slate-500 text-sm">/mo</span>
          </div>
          <p class="text-sm text-slate-500 mt-0.5">1,000 credits/mo</p>
        </div>
        <div class="mb-5">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">&euro;0.025 per credit</span>
        </div>
        <div class="w-full h-px bg-slate-100 mb-5"></div>
        <ul class="space-y-3 mb-6 flex-1">
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Everything in Pro</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Priority processing</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Credit rollover (up to 3,000)</li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>Dedicated support (direct)</li>
        </ul>
        <button
          class="w-full py-3 px-5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all duration-200 active:scale-95 shadow-lg shadow-slate-200 flex items-center justify-center cursor-pointer"
          data-plan="business_v2"
          id="btn-business"
        >
          <span class="btn-text">Subscribe</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>

    </div>

    <!-- Closet Clear Pack bar -->
    <div class="max-w-[1200px] mx-auto relative z-10 mt-6">
      <div class="bg-white border border-slate-200 rounded-3xl px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-5">
        <div>
          <p class="font-bold text-slate-900 text-base mb-1">Closet Clear Pack &mdash; &euro;3.99 one-time</p>
          <p class="text-sm text-slate-500">15 credits that never expire. No commitment. Perfect for a weekend clearout.</p>
          <span class="inline-flex items-center mt-2 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200">&euro;0.27 per credit</span>
        </div>
        <button
          class="shrink-0 px-7 py-3 rounded-xl font-bold text-sm bg-emerald-600 text-white hover:bg-emerald-700 transition-all duration-200 active:scale-95 cursor-pointer"
          id="btn-pack"
        >
          <span class="btn-text">Buy Pack</span>
          <span class="btn-status text-sm opacity-90 ml-2"></span>
        </button>
      </div>
    </div>

  </div>

  <!-- Footer strip -->
  <div class="border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-center md:text-left">
        <span class="flex items-center gap-2 text-gray-700 font-medium">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          No credit card required
        </span>
        <span class="block text-sm text-gray-500 mt-1 ml-7">Instant access to free features.</span>
      </div>
      <div class="text-center md:text-right">
        <p class="text-sm text-gray-500">Need help choosing?</p>
        <a href="mailto:support@autolister.app" class="text-gray-900 font-medium hover:underline decoration-blue-500 underline-offset-4">Email our support team &rarr;</a>
      </div>
    </div>
  </div>

  <script>
    import "../scripts/pricing.js";
  </script>
</SiteLayout>

<style>
  button.state-download {
    background-color: #059669 !important;
    color: white !important;
    border-color: #059669 !important;
  }
  button.state-download:hover {
    background-color: #047857 !important;
    border-color: #047857 !important;
  }
  button.state-signin {
    background-color: #7c3aed !important;
    color: white !important;
    border-color: #7c3aed !important;
  }
  button.state-signin:hover {
    background-color: #6d28d9 !important;
    border-color: #6d28d9 !important;
  }
  button.state-current {
    background-color: #10b981 !important;
    color: white !important;
    border-color: #10b981 !important;
    cursor: default;
    pointer-events: none;
  }
  button.state-disabled {
    background-color: #9ca3af !important;
    color: white !important;
    border-color: #9ca3af !important;
    cursor: not-allowed;
    pointer-events: none;
  }
  button:disabled {
    opacity: 0.7 !important;
    cursor: not-allowed !important;
    pointer-events: none !important;
  }
</style>
