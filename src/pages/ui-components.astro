---
const isDev = import.meta.env.DEV;

const devViews = [
  {
    title: "Extension Content Components",
    description:
      "Real content.js states rendered against mocked Vinted listing pages.",
    href: "/ui-components/content-components",
    status: "Extension preview",
  },
  {
    title: "Email Templates",
    description: "Preview outbound email templates with desktop/mobile frames.",
    href: "/email-templates",
    status: "Admin",
  },
  {
    title: "Admin Dashboard",
    description: "Users, logs, billing signals, and operational views.",
    href: "/admin/logs",
    status: "Admin",
  },
  {
    title: "Welcome Page Preview",
    description: "Locale and viewport preview for rendered welcome pages.",
    href: "/admin/ui-pages",
    status: "Admin",
  },
  {
    title: "Pricing Page",
    description: "Current public pricing UI and extension-aware checkout states.",
    href: "/pricing",
    status: "Public page",
  },
  {
    title: "Payment Complete - Starter",
    description: "Preview of the post-checkout Starter success state.",
    href: "/success.html?preview=subscription&tier=starter",
    status: "Payment preview",
  },
  {
    title: "Payment Complete - Pro",
    description: "Preview of the post-checkout Pro success state.",
    href: "/success.html?preview=subscription&tier=pro",
    status: "Payment preview",
  },
  {
    title: "Payment Complete - Business",
    description: "Preview of the post-checkout Business success state.",
    href: "/success.html?preview=subscription&tier=business",
    status: "Payment preview",
  },
  {
    title: "Payment Complete - Credits",
    description: "Preview of the one-time credit pack success state.",
    href: "/success.html?preview=credit_pack",
    status: "Payment preview",
  },
  {
    title: "Payment Complete - Error",
    description: "Preview of the payment verification failure state.",
    href: "/success.html?preview=error",
    status: "Payment preview",
  },
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>UI Components - AutoLister Dev Views</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #09090b;
        --panel: #111114;
        --panel-soft: #18181b;
        --line: #27272a;
        --text: #f4f4f5;
        --muted: #a1a1aa;
        --accent: #8b5cf6;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .shell {
        width: min(1120px, calc(100vw - 40px));
        margin: 0 auto;
        padding: 34px 0 56px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
      }

      .eyebrow {
        margin-bottom: 8px;
        color: var(--accent);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: 34px;
        line-height: 1.08;
        letter-spacing: 0;
      }

      .subtitle {
        max-width: 720px;
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .badge {
        flex: 0 0 auto;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 7px 10px;
        color: #d4d4d8;
        background: var(--panel-soft);
        font-size: 12px;
        font-weight: 750;
      }

      .notice {
        margin: 0 0 18px;
        padding: 14px 16px;
        border: 1px solid #7f1d1d;
        border-radius: 8px;
        background: #1f1111;
        color: #fecaca;
        font-size: 14px;
        line-height: 1.5;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .card {
        display: flex;
        min-height: 150px;
        flex-direction: column;
        justify-content: space-between;
        gap: 24px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        background: var(--panel);
        color: inherit;
        text-decoration: none;
        transition:
          border-color 140ms ease,
          background 140ms ease,
          transform 140ms ease;
      }

      .card:hover {
        border-color: rgba(139, 92, 246, 0.7);
        background: #15151a;
        transform: translateY(-1px);
      }

      .card.disabled {
        cursor: default;
        opacity: 0.62;
      }

      .card.disabled:hover {
        border-color: var(--line);
        background: var(--panel);
        transform: none;
      }

      .card-title {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 820;
      }

      .card-copy {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.5;
      }

      .card-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: #d4d4d8;
        font-size: 12px;
        font-weight: 750;
      }

      .arrow {
        color: var(--accent);
        font-size: 18px;
      }

      @media (max-width: 760px) {
        .shell {
          width: min(100% - 24px, 1120px);
          padding-top: 24px;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <div class="eyebrow">AutoLister Dev Views</div>
          <h1>UI Components</h1>
          <p class="subtitle">
            One local entry point for admin previews, email templates, public
            page checks, and extension component states.
          </p>
        </div>
        <div class="badge">{isDev ? "Local dev hub" : "Preview hub"}</div>
      </header>

      {!isDev && (
        <p class="notice">
          Extension previews use the latest pushed extension code. Run the
          local dev server only when you need to inspect unpushed local changes.
        </p>
      )}

      <section class="grid" aria-label="Dev views">
        {
          devViews.map((view) => {
            const isUnavailable = !isDev && view.localOnly;
            const content = (
              <>
                <div>
                  <h2 class="card-title">{view.title}</h2>
                  <p class="card-copy">{view.description}</p>
                </div>
                <div class="card-foot">
                  <span>{isUnavailable ? "Local dev only" : view.status}</span>
                  <span class="arrow" aria-hidden="true">→</span>
                </div>
              </>
            );

            return isUnavailable ? (
              <div class="card disabled" aria-disabled="true">
                {content}
              </div>
            ) : (
              <a class="card" href={view.href}>
                {content}
              </a>
            );
          })
        }
      </section>
    </main>
  </body>
</html>
