---
const sourceVersion = "20260702-limit-followup-localized-card";
const isDev = import.meta.env.DEV;
const localPreviewUrl = "http://localhost:4326/ui-components/content-components";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Content Components - AutoLister Dev Views</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f6f8fb;
        --ink: #111827;
        --muted: #667085;
        --line: #e5e7eb;
        --panel: #ffffff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .ds-shell {
        width: min(1220px, calc(100vw - 40px));
        margin: 0 auto;
        padding: 28px 0 48px;
      }

      .ds-header {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-start;
        margin-bottom: 20px;
      }

      .ds-eyebrow {
        color: #4f46e5;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      h1 {
        margin: 0;
        font-size: clamp(26px, 3vw, 38px);
        line-height: 1.08;
        letter-spacing: 0;
      }

      .ds-subtitle {
        margin: 10px 0 0;
        color: var(--muted);
        max-width: 760px;
        line-height: 1.55;
        font-size: 15px;
      }

      .ds-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 0 0 auto;
      }

      .ds-link,
      .ds-badge {
        border: 1px solid #dbe3f0;
        background: #fff;
        border-radius: 8px;
        padding: 8px 10px;
        color: #475467;
        font-size: 12px;
        font-weight: 700;
      }

      .ds-link {
        color: #4f46e5;
        text-decoration: none;
      }

      .ds-link:hover {
        border-color: #c7d2fe;
        background: #f8f7ff;
      }

      .ds-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
      }

      .ds-panel {
        min-height: 255px;
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        box-shadow: 0 10px 28px rgba(17, 24, 39, 0.06);
      }

      .ds-panel.verified {
        border-color: #bbf7d0;
      }

      .ds-panel.needs-attention {
        border-color: #fecaca;
      }

      .ds-panel.wide {
        grid-column: 1 / -1;
      }

      .ds-panel-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
      }

      .ds-panel-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 0 0 auto;
      }

      .ds-panel-title {
        margin: 0;
        font-size: 15px;
        font-weight: 800;
      }

      .ds-panel-note {
        margin: 4px 0 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.4;
      }

      .ds-stage {
        position: relative;
        min-height: 180px;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid #edf0f5;
        background: #f8fafc;
      }

      .ds-frame {
        display: block;
        width: 100%;
        border: 0;
        background: #fff;
      }

      .ds-scenario-badge {
        flex: 0 0 auto;
        border: 1px solid #d1fae5;
        border-radius: 8px;
        background: #ecfdf5;
        color: #047857;
        padding: 5px 8px;
        font-size: 11px;
        font-weight: 800;
        line-height: 1;
      }

      .ds-panel.needs-attention .ds-scenario-badge {
        border-color: #fecaca;
        background: #fef2f2;
        color: #b91c1c;
      }

      .ds-rerun {
        height: 24px;
        padding: 0 8px;
        border: 1px solid #dbe3f0;
        border-radius: 8px;
        background: #ffffff;
        color: #475467;
        cursor: pointer;
        font: inherit;
        font-size: 11px;
        font-weight: 800;
        line-height: 1;
      }

      .ds-rerun:hover {
        border-color: #c7d2fe;
        color: #3730a3;
        background: #f8f7ff;
      }

      .ds-warning {
        display: none;
        margin: 0 0 18px;
        padding: 12px 14px;
        border: 1px solid #fed7aa;
        border-radius: 12px;
        background: #fff7ed;
        color: #9a3412;
        font-size: 13px;
        line-height: 1.45;
      }

      .ds-warning a {
        color: #7c2d12;
        font-weight: 800;
      }

      @media (max-width: 820px) {
        .ds-shell {
          width: min(100% - 24px, 1180px);
          padding-top: 24px;
        }

        .ds-header {
          display: block;
        }

        .ds-actions {
          justify-content: flex-start;
          margin-top: 16px;
        }

        .ds-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <main class="ds-shell">
      <header class="ds-header">
        <div>
          <div class="ds-eyebrow">Dev-only preview</div>
          <h1>Content Components</h1>
          <p class="ds-subtitle">
            Real extension content-script states rendered inside isolated mock
            Vinted pages. This uses the current files from the extension repo,
            served by the Astro dev server.
          </p>
        </div>
        <div class="ds-actions">
          <a class="ds-link" href="/ui-components">All views</a>
          <div class="ds-badge" id="sourceStatus">Loading content.js</div>
        </div>
      </header>

      {isDev ? (
        <>
          <p class="ds-warning" id="loadWarning">
            Could not load the extension preview sources. Run the website dev
            server from the repo workspace and open this page through
            <code>/ui-components/content-components</code>.
          </p>

          <section class="ds-grid" id="previewGrid"></section>
        </>
      ) : (
        <p class="ds-warning" style="display:block;">
          This preview uses local extension files. Open the local dev preview at
          <a href={localPreviewUrl}>{localPreviewUrl}</a>.
        </p>
      )}
    </main>

    {isDev && (
      <script src={`/ui-components/content-runtime-review.js?v=${sourceVersion}`}></script>
    )}
  </body>
</html>
