---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AutoLister AI uninstall offer</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f5f7fb;
        --panel: #ffffff;
        --text: #171923;
        --muted: #667085;
        --border: #e5e7eb;
        --soft-border: #eef1f6;
        --brand: #4f46e5;
        --brand-dark: #4338ca;
        --success: #047857;
        --success-bg: #ecfdf5;
        --warning: #b45309;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(79, 70, 229, 0.13), transparent 32%),
          linear-gradient(180deg, #fbfcff 0%, var(--bg) 100%);
        color: var(--text);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        display: grid;
        place-items: center;
        padding: 28px;
      }

      main {
        width: min(100%, 960px);
        display: grid;
        grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
        gap: 18px;
      }

      .panel {
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: 0 24px 70px rgba(17, 24, 39, 0.1);
      }

      .offer {
        padding: 34px;
        position: relative;
        overflow: hidden;
      }

      .offer::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #10b981, #38bdf8, var(--brand));
      }

      .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 30px;
      }

      .brand {
        color: var(--brand);
        font-size: 18px;
        font-weight: 850;
        letter-spacing: 0;
      }

      .preview-pill {
        display: none;
        border: 1px solid #fed7aa;
        border-radius: 999px;
        padding: 6px 10px;
        background: #fff7ed;
        color: var(--warning);
        font-size: 12px;
        font-weight: 800;
      }

      [data-preview="true"] .preview-pill {
        display: inline-flex;
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--success);
        font-size: 13px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      h1 {
        max-width: 680px;
        margin: 0;
        font-size: clamp(34px, 5vw, 52px);
        line-height: 1.02;
        letter-spacing: 0;
      }

      .body-copy {
        max-width: 620px;
        margin: 18px 0 24px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.58;
      }

      .coupon-card {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        width: fit-content;
        max-width: 100%;
        margin-bottom: 24px;
        padding: 9px;
        border: 1px solid #c7d2fe;
        border-radius: 14px;
        background: #eef2ff;
      }

      .coupon-label {
        padding: 0 6px;
        color: #4338ca;
        font-size: 12px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .coupon-code {
        border: 1px solid #a5b4fc;
        border-radius: 10px;
        background: #ffffff;
        color: #111827;
        padding: 9px 12px;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: 0.04em;
      }

      .copy-code {
        appearance: none;
        border: 0;
        border-radius: 10px;
        background: var(--brand);
        color: #ffffff;
        cursor: pointer;
        font: inherit;
        font-size: 13px;
        font-weight: 850;
        padding: 10px 12px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 22px;
      }

      .cta,
      .secondary-link {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        padding: 0 18px;
        font-size: 15px;
        font-weight: 850;
        text-decoration: none;
      }

      .cta {
        background: #111827;
        color: #ffffff;
        box-shadow: 0 14px 32px rgba(17, 24, 39, 0.18);
      }

      .cta:hover,
      .cta:focus-visible {
        background: #1f2937;
      }

      .secondary-link {
        border: 1px solid var(--border);
        background: #ffffff;
        color: #344054;
      }

      .trust-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .trust-list li {
        border: 1px solid #bbf7d0;
        border-radius: 999px;
        background: var(--success-bg);
        color: var(--success);
        padding: 7px 10px;
        font-size: 12px;
        font-weight: 800;
      }

      .feedback {
        padding: 26px;
        align-self: stretch;
      }

      .feedback h2 {
        margin: 0;
        font-size: 22px;
        line-height: 1.16;
        letter-spacing: 0;
      }

      .feedback p {
        margin: 8px 0 18px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.5;
      }

      .reasons {
        display: grid;
        gap: 9px;
      }

      .reason-button {
        width: 100%;
        min-height: 46px;
        border: 1px solid var(--soft-border);
        border-radius: 11px;
        background: #ffffff;
        color: var(--text);
        cursor: pointer;
        font: inherit;
        font-size: 14px;
        font-weight: 750;
        line-height: 1.25;
        padding: 11px 12px;
        text-align: left;
        transition:
          border-color 140ms ease,
          background 140ms ease,
          transform 140ms ease;
      }

      .reason-button:hover:not(:disabled),
      .reason-button:focus-visible:not(:disabled) {
        border-color: rgba(79, 70, 229, 0.58);
        background: #f7f7ff;
        outline: none;
        transform: translateY(-1px);
      }

      .reason-button:disabled {
        cursor: wait;
        opacity: 0.72;
      }

      .thanks {
        display: none;
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: var(--success);
        border-radius: 11px;
        padding: 13px;
        font-size: 14px;
        font-weight: 800;
      }

      .error {
        display: none;
        color: #b42318;
        font-size: 13px;
        margin-top: 12px;
      }

      [data-state="submitted"] .reasons {
        display: none;
      }

      [data-state="submitted"] .thanks {
        display: block;
      }

      @media (max-width: 820px) {
        body {
          place-items: start center;
          padding: 16px;
        }

        main {
          grid-template-columns: 1fr;
        }

        .offer {
          padding: 26px;
        }
      }

      @media (max-width: 520px) {
        .offer,
        .feedback {
          padding: 22px;
          border-radius: 14px;
        }

        .brand-row {
          margin-bottom: 22px;
        }

        .coupon-card,
        .actions,
        .cta,
        .secondary-link {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main data-state="ready" data-preview="false">
      <section class="offer panel" aria-labelledby="uninstall-offer-title">
        <div class="brand-row">
          <div class="brand" data-i18n="brand">AutoLister AI</div>
          <div class="preview-pill" data-i18n="preview">Preview mode</div>
        </div>
        <p class="eyebrow" data-i18n="eyebrow">Before you go</p>
        <h1 id="uninstall-offer-title" data-i18n="headline">
          Come back with 20% off
        </h1>
        <p class="body-copy" data-i18n="body">
          Reinstall AutoLister and use this code for 20% off your first month.
        </p>

        <div class="coupon-card" aria-label="Discount code">
          <span class="coupon-label" data-i18n="couponLabel">Use code</span>
          <span class="coupon-code" data-coupon-code>{couponCode}</span>
          <button class="copy-code" type="button" data-copy-code data-i18n="copyCode">
            Copy code
          </button>
        </div>

        <div class="actions">
          <a class="cta" data-reinstall-cta href={chromeStoreUrl} data-i18n="primaryCta">
            Reinstall AutoLister
          </a>
          <a class="secondary-link" data-pricing-link href={pricingUrl} data-i18n="secondaryCta">
            See plans first
          </a>
        </div>

        <ul class="trust-list" aria-label="AutoLister safety notes">
          <li data-i18n="trustOne">Works from your listing page</li>
          <li data-i18n="trustTwo">No Vinted login required</li>
          <li data-i18n="trustThree">Secure checkout by Stripe</li>
        </ul>
      </section>

      <section class="feedback panel" aria-labelledby="uninstall-feedback-title">
        <h2 id="uninstall-feedback-title" data-i18n="feedbackTitle">
          What made you uninstall?
        </h2>
        <p data-i18n="feedbackSubtitle">One tap helps us fix the right thing.</p>
        <section class="reasons" aria-label="Uninstall feedback reasons">
          {
            feedbackReasons.map((reason) => (
              <button
                class="reason-button"
                type="button"
                data-reason={reason}
                data-label={copy.en.reasons[reason]}
              >
                {copy.en.reasons[reason]}
              </button>
            ))
          }
        </section>
        <div class="thanks" role="status" data-i18n="thanks">Thanks, that helps.</div>
        <div class="error" role="alert" data-i18n="error">
          Could not send feedback. You can close this page.
        </div>
      </section>
    </main>

    <script define:vars={{ copy, couponCode }}>
      const page = document.querySelector("main");
      const buttons = Array.from(document.querySelectorAll("[data-reason]"));
      const error = document.querySelector(".error");
      const params = new URLSearchParams(window.location.search);
      const extensionVersion = params.get("version") || null;
      const analyticsClientId = params.get("cid") || null;
      const userId = params.get("uid") || null;
      const previewMode = params.get("preview") === "1";
      const supportedLocales = Object.keys(copy);
      const uninstallOpenKey = [
        "autolister",
        "uninstall-open",
        userId || "anonymous",
        analyticsClientId || "no-cid",
        extensionVersion || "no-version",
      ].join(":");

      function normalizeLocale(value) {
        const locale = String(value || "").toLowerCase().slice(0, 2);
        return supportedLocales.includes(locale) ? locale : "en";
      }

      function getPreferredLocale() {
        return normalizeLocale(
          params.get("lang") ||
            params.get("locale") ||
            navigator.language ||
            navigator.languages?.[0],
        );
      }

      const locale = getPreferredLocale();
      const strings = copy[locale] || copy.en;
      document.documentElement.lang = strings.htmlLang || locale;
      document.title = strings.title || copy.en.title;
      page.dataset.preview = previewMode ? "true" : "false";

      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const key = element.dataset.i18n;
        if (strings[key]) element.textContent = strings[key];
      });

      buttons.forEach((button) => {
        const reason = button.dataset.reason;
        const label = strings.reasons?.[reason] || copy.en.reasons[reason];
        button.textContent = label;
        button.dataset.label = label;
      });

      function buildTrackingBody(event, context = {}) {
        return {
          event,
          source: "uninstall_page",
          page: "/uninstall",
          userId,
          context: {
            ...context,
            extensionVersion,
            analyticsClientId,
            userId,
            locale,
            couponCode,
          },
          extensionVersion,
        };
      }

      function trackEvent(event, context = {}, options = {}) {
        if (previewMode) return Promise.resolve();
        const body = JSON.stringify(buildTrackingBody(event, context));

        if (options.beacon && navigator.sendBeacon) {
          const sent = navigator.sendBeacon(
            "/api/events/track",
            new Blob([body], { type: "application/json" }),
          );
          if (sent) return Promise.resolve();
        }

        return fetch("/api/events/track", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body,
          keepalive: true,
        }).catch(() => {});
      }

      function trackUninstallOpen() {
        if (previewMode) return;
        try {
          if (window.localStorage.getItem(uninstallOpenKey)) return;
          window.localStorage.setItem(uninstallOpenKey, String(Date.now()));
        } catch {
          // Ignore storage failures; the API also dedupes uninstall opens.
        }

        trackEvent(
          "extension_uninstalled",
          {
            hasUserId: Boolean(userId),
            offerCampaign: "uninstall_winback_offer_v1",
          },
          { beacon: true },
        );
      }

      async function sendFeedback(button) {
        const reason = button.dataset.reason;
        const reasonLabel = button.dataset.label;
        if (!reason || page?.dataset.state === "submitted") return;

        buttons.forEach((item) => {
          item.disabled = true;
        });
        error.style.display = "none";

        if (previewMode) {
          page.dataset.state = "submitted";
          return;
        }

        try {
          const response = await fetch("/api/events/track", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(
              buildTrackingBody("uninstall_feedback_submitted", {
                reason,
                reasonLabel,
                offerCampaign: "uninstall_winback_offer_v1",
              }),
            ),
            keepalive: true,
          });
          if (!response.ok) {
            throw new Error(`Feedback failed: ${response.status}`);
          }
          page.dataset.state = "submitted";
        } catch (feedbackError) {
          error.style.display = "block";
          buttons.forEach((item) => {
            item.disabled = false;
          });
        }
      }

      document.querySelector("[data-copy-code]")?.addEventListener("click", async (event) => {
        const button = event.currentTarget;
        try {
          await navigator.clipboard?.writeText(couponCode);
        } catch {
          // Clipboard can fail on older browsers; the visible code still works.
        }
        button.textContent = strings.copied || copy.en.copied;
        trackEvent("uninstall_coupon_copied", {
          offerCampaign: "uninstall_winback_offer_v1",
        });
        window.setTimeout(() => {
          button.textContent = strings.copyCode || copy.en.copyCode;
        }, 1600);
      });

      document.querySelector("[data-reinstall-cta]")?.addEventListener("click", () => {
        trackEvent(
          "uninstall_reinstall_cta_click",
          {
            offerCampaign: "uninstall_winback_offer_v1",
          },
          { beacon: true },
        );
      });

      document.querySelector("[data-pricing-link]")?.addEventListener("click", () => {
        trackEvent(
          "uninstall_pricing_click",
          {
            offerCampaign: "uninstall_winback_offer_v1",
          },
          { beacon: true },
        );
      });

      buttons.forEach((button) => {
        button.addEventListener("click", () => sendFeedback(button));
      });
      trackUninstallOpen();
    </script>
  </body>
</html>
