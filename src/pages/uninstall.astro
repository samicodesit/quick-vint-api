---
const reasons = [
  {
    value: "results_not_good_enough",
    label: "The results were not good enough",
  },
  {
    value: "could_not_get_it_to_work",
    label: "I could not get it to work",
  },
  {
    value: "not_what_i_expected",
    label: "It was not what I expected",
  },
  {
    value: "wrong_app",
    label: "I thought it worked for another app",
  },
  {
    value: "free_limit_too_low",
    label: "The free limit was too low",
  },
  {
    value: "did_not_understand",
    label: "I did not understand how to use it",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AutoLister AI feedback</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f7fb;
        --panel: #ffffff;
        --text: #171923;
        --muted: #667085;
        --border: #e6e7ee;
        --brand: #4f46e5;
        --brand-dark: #4338ca;
        --success: #047857;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        display: grid;
        place-items: center;
        padding: 24px;
      }

      main {
        width: min(100%, 520px);
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: 0 18px 50px rgba(17, 24, 39, 0.08);
        padding: 34px;
      }

      .brand {
        color: var(--brand);
        font-size: 18px;
        font-weight: 800;
        margin: 0 0 28px;
      }

      h1 {
        margin: 0;
        font-size: 24px;
        line-height: 1.18;
        letter-spacing: 0;
      }

      p {
        margin: 10px 0 22px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .reasons {
        display: grid;
        gap: 10px;
      }

      button {
        width: 100%;
        min-height: 50px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: #ffffff;
        color: var(--text);
        cursor: pointer;
        font: inherit;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.25;
        padding: 12px 14px;
        text-align: left;
        transition:
          border-color 140ms ease,
          background 140ms ease,
          color 140ms ease,
          transform 140ms ease;
      }

      button:hover:not(:disabled),
      button:focus-visible:not(:disabled) {
        border-color: rgba(79, 70, 229, 0.58);
        background: #f7f7ff;
        outline: none;
        transform: translateY(-1px);
      }

      button:disabled {
        cursor: wait;
        opacity: 0.72;
      }

      .thanks {
        display: none;
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: var(--success);
        border-radius: 8px;
        padding: 14px;
        font-size: 15px;
        font-weight: 750;
      }

      .error {
        display: none;
        color: #b42318;
        font-size: 13px;
        margin-top: 12px;
      }

      [data-state="submitted"] .reasons,
      [data-state="submitted"] .intro {
        display: none;
      }

      [data-state="submitted"] .thanks {
        display: block;
      }

      @media (max-width: 520px) {
        body {
          align-items: start;
          padding: 16px;
        }

        main {
          padding: 24px;
        }

        h1 {
          font-size: 22px;
        }
      }
    </style>
  </head>
  <body>
    <main data-state="ready">
      <div class="brand">AutoLister AI</div>
      <section class="intro">
        <h1>What made you uninstall AutoLister AI?</h1>
        <p>One tap helps us improve.</p>
      </section>
      <section class="reasons" aria-label="Uninstall feedback reasons">
        {
          reasons.map((reason) => (
            <button type="button" data-reason={reason.value} data-label={reason.label}>
              {reason.label}
            </button>
          ))
        }
      </section>
      <div class="thanks" role="status">Thanks, that helps.</div>
      <div class="error" role="alert">
        Could not send feedback. You can close this page.
      </div>
    </main>

    <script>
      const page = document.querySelector("main");
      const buttons = Array.from(document.querySelectorAll("[data-reason]"));
      const error = document.querySelector(".error");
      const params = new URLSearchParams(window.location.search);
      const extensionVersion = params.get("version") || null;
      const analyticsClientId = params.get("cid") || null;

      async function sendFeedback(button) {
        const reason = button.dataset.reason;
        const reasonLabel = button.dataset.label;
        if (!reason || page?.dataset.state === "submitted") return;

        buttons.forEach((item) => {
          item.disabled = true;
        });
        error.style.display = "none";

        try {
          const response = await fetch("/api/events/track", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              event: "uninstall_feedback_submitted",
              source: "uninstall_page",
              page: "/uninstall",
              context: {
                reason,
                reasonLabel,
                extensionVersion,
                analyticsClientId,
              },
              extensionVersion,
            }),
            keepalive: true,
          });
          if (!response.ok) {
            throw new Error(`Feedback failed: ${response.status}`);
          }
          page.dataset.state = "submitted";
        } catch (feedbackError) {
          error.style.display = "block";
          buttons.forEach((item) => {
            item.disabled = false;
          });
        }
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => sendFeedback(button));
      });
    </script>
  </body>
</html>
