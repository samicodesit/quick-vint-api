---
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  DEFAULT_WELCOME_LOCALE,
  SUPPORTED_WELCOME_LOCALES,
} from "../i18n/welcome.js";

const fallbackPath = `/welcome/${DEFAULT_WELCOME_LOCALE}`;
---

<SiteLayout
  title="Welcome to AutoLister AI"
  description="Redirecting to your localized AutoLister AI welcome page."
  canonical="https://autolister.app/welcome"
  ogUrl="https://autolister.app/welcome"
  htmlLang="en"
>
  <main class="pt-32 pb-16 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto">
    <section
      class="rounded-3xl border border-slate-200 bg-white shadow-sm p-8 text-center"
    >
      <h1 class="text-3xl font-extrabold text-slate-900 mb-3">
        Setting up your welcome page
      </h1>
      <p class="text-slate-600 mb-6">
        Redirecting you to the best language experience.
      </p>
      <a
        href={fallbackPath}
        class="inline-flex items-center justify-center px-6 py-3 rounded-2xl bg-brand-600 text-white font-bold hover:bg-brand-700 no-underline"
      >
        Continue
      </a>

      <noscript>
        <p class="text-sm text-slate-600 mt-4 mb-2">Choose your language:</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/welcome/en" class="text-brand-700 font-semibold">English</a>
          <a href="/welcome/fr" class="text-brand-700 font-semibold">Français</a
          >
          <a href="/welcome/de" class="text-brand-700 font-semibold">Deutsch</a>
          <a href="/welcome/nl" class="text-brand-700 font-semibold"
            >Nederlands</a
          >
          <a href="/welcome/pl" class="text-brand-700 font-semibold">Polski</a>
          <a href="/welcome/es" class="text-brand-700 font-semibold">Español</a>
          <a href="/welcome/it" class="text-brand-700 font-semibold">Italiano</a
          >
          <a href="/welcome/pt" class="text-brand-700 font-semibold"
            >Português</a
          >
        </div>
      </noscript>
    </section>
  </main>

  <script
    is:inline
    define:vars={{ fallbackPath, supportedLocales: SUPPORTED_WELCOME_LOCALES }}
  >
    function normalizeLocale(input) {
      if (!input) return "en";
      const lowerValue = String(input).toLowerCase();
      const shortCode = lowerValue.split(/[-_]/)[0];
      if (supportedLocales.includes(lowerValue)) return lowerValue;
      if (supportedLocales.includes(shortCode)) return shortCode;
      return "en";
    }

    function getPreferredLocale() {
      const params = new URLSearchParams(window.location.search);
      const requestedLang = params.get("lang");
      if (requestedLang) {
        return normalizeLocale(requestedLang);
      }

      const browserLang =
        navigator.language ||
        (navigator.languages && navigator.languages[0]) ||
        "en";
      return normalizeLocale(browserLang);
    }

    function preserveParams(path) {
      const params = new URLSearchParams(window.location.search);
      if (!params.toString()) return path;
      return `${path}?${params.toString()}`;
    }

    const preferredLocale = getPreferredLocale();
    const locale = supportedLocales.includes(preferredLocale)
      ? preferredLocale
      : "en";
    const targetPath = preserveParams(`/welcome/${locale}`);

    const normalizedPath = window.location.pathname.replace(/\/+$/, "") || "/";

    if (normalizedPath === "/welcome") {
      window.location.replace(targetPath);
    }
  </script>
</SiteLayout>
