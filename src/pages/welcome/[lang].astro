---
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  DEFAULT_WELCOME_LOCALE,
  SUPPORTED_WELCOME_LOCALES,
  WELCOME_COPY,
  normalizeWelcomeLocale,
} from "../../i18n/welcome.js";
import type { WelcomeLocale } from "../../i18n/welcome.js";

export function getStaticPaths() {
  return SUPPORTED_WELCOME_LOCALES.map((lang: WelcomeLocale) => ({
    params: { lang },
  }));
}

const locale = normalizeWelcomeLocale(Astro.params.lang);
const copy = WELCOME_COPY[locale];
const baseUrl = "https://autolister.app";
const welcomePath = `/welcome/${locale}`;
const canonical = `${baseUrl}${welcomePath}`;
---

<SiteLayout
  title={copy.seoTitle}
  description={copy.seoDescription}
  canonical={canonical}
  ogUrl={canonical}
  htmlLang={locale}
  currentLocale={locale}
  pathPattern="/welcome/{lang}"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${baseUrl}/welcome/en`} />
    <link rel="alternate" hreflang="fr" href={`${baseUrl}/welcome/fr`} />
    <link rel="alternate" hreflang="de" href={`${baseUrl}/welcome/de`} />
    <link rel="alternate" hreflang="nl" href={`${baseUrl}/welcome/nl`} />
    <link rel="alternate" hreflang="pl" href={`${baseUrl}/welcome/pl`} />
    <link rel="alternate" hreflang="es" href={`${baseUrl}/welcome/es`} />
    <link rel="alternate" hreflang="it" href={`${baseUrl}/welcome/it`} />
    <link rel="alternate" hreflang="pt" href={`${baseUrl}/welcome/pt`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/welcome/en`} />
  </Fragment>

  <main class="relative min-h-[calc(100vh-80px)] pt-24 pb-16 lg:pt-32 lg:pb-24 overflow-hidden bg-slate-50 flex items-center">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-100 rounded-full blur-3xl opacity-50 mix-blend-multiply"></div>
      <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-indigo-100 rounded-full blur-3xl opacity-50 mix-blend-multiply"></div>
    </div>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
      <div class="bg-white/90 backdrop-blur-md border border-slate-200 rounded-3xl p-6 sm:p-10 lg:p-12 shadow-xl shadow-slate-200/40 grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
        
        <!-- Left Column: Content -->
        <div class="flex flex-col text-left">
          <div class="flex flex-col gap-4 mb-8">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-100 border border-brand-200 text-brand-800 text-xs font-bold uppercase tracking-wider w-fit">
              <svg class="w-4 h-4 mr-1.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              {copy.heroBadge}
            </span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-[1.1] text-balance mb-6">
            {copy.heroTitle}
          </h1>

          <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-lg">
            {copy.heroSubtitle}
          </p>

          <!-- Streamlined Steps -->
          <div class="space-y-6 mb-10">
            <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider">{copy.stepsTitle}</h2>
            <div class="space-y-5">
              {copy.steps.map((step: string, index: number) => (
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-bold border border-brand-100 shadow-sm mt-0.5">
                    {index + 1}
                  </div>
                  <div class="pt-1 text-slate-800 font-medium">
                    {step}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a
              id="welcome-primary-cta"
              href="https://www.vinted.com/items/new"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-bold text-white bg-brand-600 rounded-xl hover:bg-brand-700 transition-all hover:-translate-y-1 shadow-lg shadow-brand-600/25 no-underline w-full sm:w-auto"
            >
              {copy.primaryCta}
            </a>
            <a
              id="welcome-pricing-cta"
              href="/pricing"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-bold text-slate-700 bg-white border-2 border-slate-200 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all hover:-translate-y-1 no-underline w-full sm:w-auto"
            >
              {copy.secondaryCta}
            </a>
          </div>

          <div class="mt-4 flex flex-col gap-3">
            <div class="inline-flex items-start sm:items-center gap-3 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-100/80 w-fit">
              <span class="flex items-center justify-center w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 shrink-0">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </span>
              <p class="text-[15px] font-semibold text-emerald-800 leading-snug m-0">{copy.reassurance}</p>
            </div>
            <p class="text-xs text-slate-400 font-medium pl-1 max-w-sm leading-relaxed">{copy.compliance}</p>
          </div>
        </div>

        <!-- Right Column: Image Guide -->
        <div class="relative w-full max-w-[440px] mx-auto lg:mx-0 lg:ml-auto flex flex-col gap-6">
          
          <!-- Step 1 Card -->
          <div class="bg-white rounded-2xl border border-slate-200 p-5 sm:p-6 shadow-sm shadow-slate-200/50">
            <div class="flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-bold text-sm">
                  1
                </div>
                <h3 class="text-[15px] font-bold text-slate-900">Click &quot;Extensions&quot;</h3>
              </div>
              <div class="rounded-xl overflow-hidden bg-[#f8fafc] flex items-center justify-center py-4 px-2 border border-slate-100">
                <img src="/extensions-icon.jpg" alt="Click the Extensions icon in your browser" class="h-[70px] w-auto object-contain mix-blend-multiply" />
              </div>
            </div>
          </div>

          <!-- Step 2 Card -->
          <div class="bg-white rounded-2xl border border-slate-200 p-5 sm:p-6 shadow-sm shadow-slate-200/50">
            <div class="flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-bold text-sm">
                  2
                </div>
                <h3 class="text-[15px] font-bold text-slate-900">Pin AutoLister AI</h3>
              </div>
              <div class="rounded-xl overflow-hidden bg-[#f8fafc] flex items-center justify-center pt-5 pb-0 px-2 border border-slate-100">
                <img src="/pin-it.png" alt="Click the pin icon next to AutoLister AI" class="h-[200px] w-auto object-contain object-bottom" />
              </div>
            </div>
          </div>

          <div class="mt-1 text-center px-4 w-full">
            <p class="text-[13px] font-medium text-slate-500 flex items-center justify-center gap-2 mx-auto bg-slate-50/80 rounded-full py-2 px-5 w-fit border border-slate-200/60">
              <svg class="w-[18px] h-[18px] text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Pin AutoLister AI to easily access it later
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <script
    is:inline
    define:vars={{ locale, welcomePath, defaultLocale: DEFAULT_WELCOME_LOCALE }}
  >
    const VINTED_DOMAINS = {
      FR: "vinted.fr",
      DE: "vinted.de",
      GB: "vinted.co.uk",
      UK: "vinted.co.uk",
      ES: "vinted.es",
      IT: "vinted.it",
      BE: "vinted.be",
      NL: "vinted.nl",
      AT: "vinted.at",
      PL: "vinted.pl",
      CZ: "vinted.cz",
      LT: "vinted.lt",
      LV: "vinted.lv",
      LU: "vinted.lu",
      PT: "vinted.pt",
      US: "vinted.com",
      CA: "vinted.ca",
      DEFAULT: "vinted.com",
    };

    const TIMEZONE_TO_COUNTRY = {
      "Europe/Paris": "FR",
      "Europe/Berlin": "DE",
      "Europe/London": "GB",
      "Europe/Madrid": "ES",
      "Europe/Rome": "IT",
      "Europe/Brussels": "BE",
      "Europe/Amsterdam": "NL",
      "Europe/Vienna": "AT",
      "Europe/Warsaw": "PL",
      "Europe/Prague": "CZ",
      "Europe/Vilnius": "LT",
      "Europe/Riga": "LV",
      "Europe/Luxembourg": "LU",
      "Europe/Lisbon": "PT",
      "America/New_York": "US",
      "America/Chicago": "US",
      "America/Denver": "US",
      "America/Los_Angeles": "US",
      "America/Toronto": "CA",
      "America/Vancouver": "CA",
      "America/Montreal": "CA",
    };

    const primaryCta = document.getElementById("welcome-primary-cta");
    const pricingCta = document.getElementById("welcome-pricing-cta");

    function getQueryParams() {
      const params = new URLSearchParams(window.location.search);
      return {
        source: params.get("source") || params.get("utm_source") || "unknown",
        medium: params.get("medium") || params.get("utm_medium") || "unknown",
        campaign:
          params.get("campaign") || params.get("utm_campaign") || "unknown",
      };
    }

    function detectCountryCode() {
      try {
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const timezoneCountry = TIMEZONE_TO_COUNTRY[timezone];
        if (timezoneCountry) return timezoneCountry;
      } catch (_error) {
        // fall through
      }

      const languageCandidates = [
        navigator.language,
        ...(navigator.languages || []),
      ].filter(Boolean);
      for (const langEntry of languageCandidates) {
        const region = langEntry.split(/[-_]/)[1]?.toUpperCase();
        if (region && VINTED_DOMAINS[region]) {
          return region;
        }
      }

      return "DEFAULT";
    }

    function getVintedListingUrl() {
      const countryCode = detectCountryCode();
      const domain = VINTED_DOMAINS[countryCode] || VINTED_DOMAINS.DEFAULT;
      return `https://www.${domain}/items/new`;
    }

    function sendGtagEvent(eventName, extra = {}) {
      const payload = {
        locale,
        page_path: welcomePath,
        ...getQueryParams(),
        ...extra,
      };

      if (typeof window.gtag === "function") {
        window.gtag("event", eventName, payload);
        return;
      }

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: eventName, ...payload });
    }

    function withExistingQueryParams(url) {
      const finalUrl = new URL(url, window.location.origin);
      const currentParams = new URLSearchParams(window.location.search);
      for (const [key, value] of currentParams.entries()) {
        finalUrl.searchParams.set(key, value);
      }
      return finalUrl.pathname + finalUrl.search;
    }

    if (primaryCta) {
      primaryCta.href = getVintedListingUrl();
      primaryCta.addEventListener("click", () => {
        sendGtagEvent("welcome_primary_cta_click", {
          target_url: primaryCta.href,
          detected_country: detectCountryCode(),
        });
      });
    }

    if (pricingCta) {
      pricingCta.href = withExistingQueryParams("/pricing");
      pricingCta.addEventListener("click", () => {
        sendGtagEvent("welcome_secondary_pricing_click");
      });
    }

    document.querySelectorAll("[data-lang-option]").forEach((langLink) => {
      langLink.addEventListener("click", (event) => {
        // The URL is already a localized path because LanguageSwitcher generated it,
        // we just parse the final lang out from the generated href for tracking
        const hrefUrl = new URL(langLink.href, window.location.origin);
        // Extracts the language part after 'welcome/' or leading slashes
        const selectedLocale = hrefUrl.pathname.split("/").pop() || defaultLocale;
        
        sendGtagEvent("welcome_language_switch_click", {
          selected_locale: selectedLocale,
        });
      });
    });
  </script>
</SiteLayout>
