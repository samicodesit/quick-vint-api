{
  "rewrites": [
    {
      "source": "/admin/:view",
      "destination": "/admin"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-counts",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/daily-cleanup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/dom-canary-heartbeat",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/billing-reconciliation",
      "schedule": "45 7 * * *"
    }
  ]
}
